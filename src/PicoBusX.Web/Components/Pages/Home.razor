@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject NavigationManager NavigationManager
@inject IExplorerService Explorer
@inject MessageSenderService Sender
@inject MessageBrowserService Browser
@inject EntityManagementService EntityManager
@inject Microsoft.Extensions.Options.IOptions<ServiceBusConnectionOptions> BusOptions
@inject ServiceBusClientFactory Factory
@inject NavigationManager Nav
@inject ILogger<Home> Logger
@inject IToastService ToastService

<PageTitle>PicoBusX – Azure Service Bus Explorer</PageTitle>

<div class="dashboard">
    <!-- Left panel: Tree View -->
    <div class="panel-tree">
        <BusTreeView
            Queues="@_queues" 
            Topics="@_topics" 
            OnEntitySelected="HandleEntitySelected"
            IsLoading="@_loading"
            ErrorMessage="@_loadError"
            WarningMessage="@_loadWarning" />
        <div class="tree-actions">
            <FluentButton Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size16.Add())"
                          OnClick="OpenCreateDialog"
                          Style="width: 100%; margin-bottom: 0.4rem;">
                New Entity
            </FluentButton>
            <FluentButton Appearance="Appearance.Stealth" 
                          IconStart="@(new Icons.Regular.Size16.ArrowSync())"
                          OnClick="LoadDataAsync"
                          Disabled="@_loading"
                          Style="width: 100%;">
                @if (_loading) { <span>Loading…</span> } else { <span>Refresh</span> }
            </FluentButton>
        </div>
    </div>

    <!-- Right panel: Details + Send + Peek -->
    <div class="panel-main">
        @if (_selectedEntity is null)
        {
            <div class="empty-state">
                <div class="empty-icon">🚌</div>
                <h2>PicoBusX</h2>
                @if (!Factory.IsConfigured)
                {
                    <p>No Azure Service Bus connection is configured.</p>
                    <div style="margin-top: 1.25rem;">
                        <FluentButton Appearance="Appearance.Accent"
                                      IconStart="@(new Icons.Regular.Size20.Settings())"
                                      OnClick="@(() => Nav.NavigateTo("/settings"))">
                            Configure Connection
                        </FluentButton>
                    </div>
                }
                else
                {
                    <p>Select a queue, topic, or subscription from the tree to get started.</p>
                    @if (!string.IsNullOrEmpty(_connectionStatus))
                    {
                        <FluentBadge Appearance="@(_isConnected ? Appearance.Accent : Appearance.Neutral)"
                                     Style="margin-top: 1rem; font-size: 0.875rem; padding: 0.5rem 1rem;">
                            @(_isConnected ? "✅ Connected" : "❌ Not Connected") — @_connectionStatus
                        </FluentBadge>
                    }
                }
            </div>
        }
        else
        {
            <div class="entity-header">
                <FluentBadge Appearance="Appearance.Accent" 
                             BackgroundColor="@GetEntityColor(_selectedEntity.Type)"
                             Color="white">
                    @_selectedEntity.Type
                </FluentBadge>
                <h2 style="margin: 0; font-size: 1.3rem;">@_selectedEntity.Name</h2>
                @if (_selectedEntity.TopicName is not null)
                {
                    <span class="entity-parent">under @_selectedEntity.TopicName</span>
                }
                <FluentButton Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Delete())"
                              OnClick="OpenDeleteDialog"
                              Style="margin-left: auto; color: #dc2626; border-color: #dc2626;"
                              Title="Delete this entity">
                    Delete
                </FluentButton>
            </div>

            <FluentTabs ActiveTabId="@_activeTab" OnTabChange="HandleTabChange">
                <FluentTab Id="details" Label="Details" Icon="@(new Icons.Regular.Size16.List())">
                    <EntityDetailsPanel Entity="@_selectedEntity" Queues="@_queues" Topics="@_topics" />
                </FluentTab>
                @if (_selectedEntity.Type != BusEntityType.Topic)
                {
                    <FluentTab Id="send" Label="Send Message" Icon="@(new Icons.Regular.Size16.Send())">
                        <JsonMessageEditor 
                            Destination="@_selectedEntity.EntityPath"
                            OnSend="HandleSendMessage"
                            IsSending="@_sending"
                            SendResult="@_sendResult"
                            SendError="@_sendError" />
                    </FluentTab>
                    <FluentTab Id="peek" Label="Peek / Read" Icon="@(new Icons.Regular.Size16.Eye())">
                        <PeekReadPanel 
                            EntityPath="@_selectedEntity.EntityPath"
                            DefaultMaxCount="@BusOptions.Value.EntityMaxPeek"
                            OnPeek="HandlePeekAsync"
                            OnReceive="HandleReceiveAsync"
                            Messages="@_browsedMessages"
                            IsBusy="@_browsing"
                            ErrorMessage="@_browseError" />
                    </FluentTab>
                    <FluentTab Id="dlq" Label="Dead Letter" Icon="@(new Icons.Regular.Size16.Warning())">
                        <DlqPanel
                            EntityPath="@_selectedEntity.EntityPath"
                            DefaultMaxCount="@BusOptions.Value.EntityMaxPeek"
                            OnPeek="HandleDlqPeekAsync"
                            OnResubmit="HandleDlqResubmitAsync"
                            Messages="@_dlqMessages"
                            IsBusy="@_dlqBusy"
                            ErrorMessage="@_dlqError" />
                    </FluentTab>
                }
                else
                {
                    <FluentTab Id="send" Label="Send to Topic" Icon="@(new Icons.Regular.Size16.Send())">
                        <JsonMessageEditor 
                            Destination="@_selectedEntity.EntityPath"
                            OnSend="HandleSendMessage"
                            IsSending="@_sending"
                            SendResult="@_sendResult"
                            SendError="@_sendError" />
                    </FluentTab>
                }
            </FluentTabs>
        }
    </div>
</div>

<!-- Create Entity Dialog -->
<FluentDialog @ref="_createDialog"
              Hidden="@_createDialogHidden"
              Modal="true"
              TrapFocus="true"
              PreventScroll="true"
              @ondialogdismiss="CloseCreateDialog">
    <FluentDialogHeader ShowDismiss="true">
        <strong>Create New Entity</strong>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; padding: 0.5rem 0; min-width: 320px;">
            <FluentSelect TOption="string"
                          Label="Entity Type"
                          @bind-Value="_newEntityType"
                          Style="width: 100%;">
                <FluentOption TOption="string" Value="queue">Queue</FluentOption>
                <FluentOption TOption="string" Value="topic">Topic</FluentOption>
                <FluentOption TOption="string" Value="subscription">Subscription</FluentOption>
            </FluentSelect>

            @if (_newEntityType == "subscription")
            {
                <FluentTextField Label="Topic Name"
                                 @bind-Value="_newTopicName"
                                 Placeholder="existing-topic-name"
                                 Style="width: 100%;" />
            }

            <FluentTextField Label="@(_newEntityType == "subscription" ? "Subscription Name" : "Name")"
                             @bind-Value="_newEntityName"
                             Placeholder="my-entity-name"
                             Style="width: 100%;" />

            @if (!string.IsNullOrEmpty(_createEntityError))
            {
                <FluentMessageBar Intent="MessageIntent.Error">@_createEntityError</FluentMessageBar>
            }
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="SubmitCreateEntityAsync"
                      Disabled="@_creatingEntity">
            @if (_creatingEntity) { <span>Creating…</span> } else { <span>Create</span> }
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="CloseCreateDialog">Cancel</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

<!-- Delete Entity Dialog -->
<FluentDialog @ref="_deleteDialog"
              Hidden="@_deleteDialogHidden"
              Modal="true"
              TrapFocus="true"
              PreventScroll="true"
              @ondialogdismiss="CloseDeleteDialog">
    <FluentDialogHeader ShowDismiss="true">
        <strong>Delete Entity</strong>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem; padding: 0.5rem 0;">
            <p>Are you sure you want to delete <strong>@_selectedEntity?.Name</strong>?</p>
            <p style="color: #dc2626; font-size: 0.85rem;">⚠️ This action cannot be undone. All messages will be lost.</p>
            @if (!string.IsNullOrEmpty(_deleteEntityError))
            {
                <FluentMessageBar Intent="MessageIntent.Error">@_deleteEntityError</FluentMessageBar>
            }
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="SubmitDeleteEntityAsync"
                      Disabled="@_deletingEntity"
                      Style="background: #dc2626;">
            @if (_deletingEntity) { <span>Deleting…</span> } else { <span>Delete</span> }
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="CloseDeleteDialog">Cancel</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private List<QueueInfo> _queues = new();
    private List<TopicInfo> _topics = new();
    [SupplyParameterFromQuery(Name = "name")]
    [Parameter]
    public string? EntityName { get; set; }

    [SupplyParameterFromQuery(Name = "type")]
    [Parameter]
    public string? EntityType { get; set; }

    [SupplyParameterFromQuery(Name = "topicName")]
    [Parameter]
    public string? TopicName { get; set; }

    private BusEntity? _selectedEntity;

    protected override void OnParametersSet()
    {
        BusEntity? newEntity = null;

        if (EntityName is not null && EntityType is not null)
        {
            if (Enum.TryParse<BusEntityType>(EntityType, ignoreCase: true, out var entityType))
            {
                newEntity = new BusEntity
                {
                    Type = entityType,
                    Name = EntityName,
                    TopicName = TopicName
                };
            }
        }

        var selectionChanged = (_selectedEntity is null) != (newEntity is null)
            || (_selectedEntity is not null && newEntity is not null
                && (_selectedEntity.Type != newEntity.Type
                    || _selectedEntity.Name != newEntity.Name
                    || _selectedEntity.TopicName != newEntity.TopicName));

        if (selectionChanged)
        {
            _selectedEntity = newEntity;
            ResetEntityScopedState();
        }
    }
    private string _activeTab = "details";
    private bool _loading;
    private string? _loadError;
    private string? _loadWarning;
    private bool _isConnected;
    private string _connectionStatus = string.Empty;

    private bool _sending;
    private string? _sendResult;
    private string? _sendError;

    private List<BrowsedMessage> _browsedMessages = new();
    private bool _browsing;
    private string? _browseError;

    private List<BrowsedMessage> _dlqMessages = new();
    private bool _dlqBusy;
    private string? _dlqError;

    // Create entity dialog state
    private FluentDialog? _createDialog;
    private bool _createDialogHidden = true;
    private string _newEntityType = "queue";
    private string _newEntityName = string.Empty;
    private string? _newTopicName;
    private bool _creatingEntity;
    private string? _createEntityError;

    // Delete entity dialog state
    private FluentDialog? _deleteDialog;
    private bool _deleteDialogHidden = true;
    private bool _deletingEntity;
    private string? _deleteEntityError;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _loadError = null;
        _loadWarning = null;
        _isConnected = false;
        StateHasChanged();

        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            var loadResult = await Explorer.LoadAsync(cts.Token);

            _queues = loadResult.Queues;
            _topics = loadResult.Topics;
            _loadWarning = loadResult.WarningMessage;
            _loadError = loadResult.ErrorMessage;

            RestoreSelectionAfterReload();

            if (loadResult.HasError)
            {
                _connectionStatus = loadResult.ErrorMessage!;
                return;
            }

            if (loadResult.HasWarning)
            {
                _connectionStatus = loadResult.WarningMessage!;
                return;
            }

            _isConnected = true;
            _connectionStatus = $"Loaded {_queues.Count} queues, {_topics.Count} topics";
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            _connectionStatus = ex.Message;
            Logger.LogError(ex, "Failed to load Service Bus data");
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleEntitySelected(BusEntity entity)
    {
        _selectedEntity = entity;
        NavigationManager.NavigateTo(NavigationManager.GetUriWithQueryParameters("/", new Dictionary<string, object?>
        {
            { "name", entity.Name },
            { "type", entity.Type.ToString() },
            { "topicName", entity.TopicName }
        }));
        ResetEntityScopedState();
    }

    private void ResetEntityScopedState()
    {
        _activeTab = "details";
        _browsedMessages = new();
        _sendResult = null;
        _sendError = null;
        _browseError = null;
        _dlqMessages = new();
        _dlqError = null;
    }

    private void HandleTabChange(FluentTab tab)
    {
        _activeTab = tab.Id ?? "details";
    }

    private async Task HandleSendMessage(SendMessageRequest request)
    {
        _sending = true;
        _sendResult = null;
        _sendError = null;
        StateHasChanged();
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            await Sender.SendMessageAsync(request, cts.Token);
            _sendResult = "Message sent successfully!";
            ToastService.ShowSuccess("Message sent successfully!");
        }
        catch (Exception ex)
        {
            _sendError = ex.Message;
            ToastService.ShowError($"Send failed: {ex.Message}");
            Logger.LogError(ex, "Failed to send message");
        }
        finally
        {
            _sending = false;
        }
    }

    private async Task HandlePeekAsync((string entityPath, int maxCount) args)
    {
        _browsing = true;
        _browseError = null;
        _browsedMessages = new();
        StateHasChanged();
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            _browsedMessages = await Browser.PeekMessagesAsync(args.entityPath, args.maxCount, cts.Token);
        }
        catch (Exception ex)
        {
            _browseError = ex.Message;
            Logger.LogError(ex, "Failed to peek messages");
        }
        finally
        {
            _browsing = false;
        }
    }

    private async Task HandleReceiveAsync((string entityPath, int maxCount) args)
    {
        _browsing = true;
        _browseError = null;
        _browsedMessages = new();
        StateHasChanged();
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            _browsedMessages = await Browser.ReceiveAndAbandonAsync(args.entityPath, args.maxCount, cts.Token);
        }
        catch (Exception ex)
        {
            _browseError = ex.Message;
            Logger.LogError(ex, "Failed to receive messages");
        }
        finally
        {
            _browsing = false;
        }
    }

    private async Task HandleDlqPeekAsync((string entityPath, int maxCount) args)
    {
        _dlqBusy = true;
        _dlqError = null;
        _dlqMessages = new();
        StateHasChanged();
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            _dlqMessages = await Browser.PeekDeadLetterAsync(args.entityPath, args.maxCount, cts.Token);
        }
        catch (Exception ex)
        {
            _dlqError = ex.Message;
            Logger.LogError(ex, "Failed to peek DLQ messages");
        }
        finally
        {
            _dlqBusy = false;
        }
    }

    private async Task HandleDlqResubmitAsync(long sequenceNumber)
    {
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            await Browser.ResubmitDeadLetterAsync(_selectedEntity!.EntityPath, sequenceNumber, cts.Token);
            ToastService.ShowSuccess($"Message #{sequenceNumber} resubmitted successfully!");
            _dlqMessages = _dlqMessages.Where(m => m.SequenceNumber != sequenceNumber).ToList();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Resubmit failed: {ex.Message}");
            Logger.LogError(ex, "Failed to resubmit DLQ message");
        }
    }

    private void OpenCreateDialog()
    {
        _newEntityType = "queue";
        _newEntityName = string.Empty;
        _newTopicName = null;
        _createEntityError = null;
        _createDialogHidden = false;
    }

    private void CloseCreateDialog() => _createDialogHidden = true;

    private async Task SubmitCreateEntityAsync()
    {
        if (string.IsNullOrWhiteSpace(_newEntityName))
        {
            _createEntityError = "Name is required.";
            return;
        }
        if (_newEntityType == "subscription" && string.IsNullOrWhiteSpace(_newTopicName))
        {
            _createEntityError = "Topic Name is required for subscriptions.";
            return;
        }
        _creatingEntity = true;
        _createEntityError = null;
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            switch (_newEntityType)
            {
                case "queue":
                    await EntityManager.CreateQueueAsync(_newEntityName.Trim(), cts.Token);
                    break;
                case "topic":
                    await EntityManager.CreateTopicAsync(_newEntityName.Trim(), cts.Token);
                    break;
                case "subscription":
                    await EntityManager.CreateSubscriptionAsync(_newTopicName!.Trim(), _newEntityName.Trim(), cts.Token);
                    break;
            }
            ToastService.ShowSuccess($"{char.ToUpper(_newEntityType[0])}{_newEntityType[1..]} '{_newEntityName}' created successfully!");
            CloseCreateDialog();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _createEntityError = ex.Message;
            Logger.LogError(ex, "Failed to create entity");
        }
        finally
        {
            _creatingEntity = false;
        }
    }

    private void OpenDeleteDialog()
    {
        _deleteEntityError = null;
        _deleteDialogHidden = false;
    }

    private void CloseDeleteDialog() => _deleteDialogHidden = true;

    private async Task SubmitDeleteEntityAsync()
    {
        if (_selectedEntity is null) return;
        _deletingEntity = true;
        _deleteEntityError = null;
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            switch (_selectedEntity.Type)
            {
                case BusEntityType.Queue:
                    await EntityManager.DeleteQueueAsync(_selectedEntity.Name, cts.Token);
                    break;
                case BusEntityType.Topic:
                    await EntityManager.DeleteTopicAsync(_selectedEntity.Name, cts.Token);
                    break;
                case BusEntityType.Subscription:
                    await EntityManager.DeleteSubscriptionAsync(_selectedEntity.TopicName!, _selectedEntity.Name, cts.Token);
                    break;
            }
            ToastService.ShowSuccess($"{_selectedEntity.Type} '{_selectedEntity.Name}' deleted successfully!");
            _selectedEntity = null;
            CloseDeleteDialog();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _deleteEntityError = ex.Message;
            Logger.LogError(ex, "Failed to delete entity");
        }
        finally
        {
            _deletingEntity = false;
        }
    }

    private void RestoreSelectionAfterReload()
    {
        if (_selectedEntity is null)
        {
            return;
        }

        var queueExists = _selectedEntity.Type == BusEntityType.Queue && _queues.Any(q => q.Name == _selectedEntity.Name);
        var topicExists = _selectedEntity.Type == BusEntityType.Topic && _topics.Any(t => t.Name == _selectedEntity.Name);
        var subscriptionExists = _selectedEntity.Type == BusEntityType.Subscription &&
                                 _topics.Any(t => t.Name == _selectedEntity.TopicName && t.Subscriptions.Any(s => s.Name == _selectedEntity.Name));

        if (!queueExists && !topicExists && !subscriptionExists)
        {
            _selectedEntity = null;
            _activeTab = "details";
            _browsedMessages.Clear();
            _dlqMessages.Clear();
        }
    }

    private static string GetEntityColor(BusEntityType type) => type switch
    {
        BusEntityType.Queue => "#1e40af",
        BusEntityType.Topic => "#92400e",
        BusEntityType.Subscription => "#065f46",
        _ => "#1e40af"
    };

}
