    private List<SubscriptionRuleInfo> GetSelectedSubscriptionRules()
    {
        if (_selectedEntity is null || _selectedEntity.Type != BusEntityType.Subscription || string.IsNullOrWhiteSpace(_selectedEntity.TopicName))
        {
            return new List<SubscriptionRuleInfo>();
        }

        var topic = _topics.FirstOrDefault(t => t.Name == _selectedEntity.TopicName);
        var subscription = topic?.Subscriptions.FirstOrDefault(s => s.Name == _selectedEntity.Name);

        return subscription?.Rules ?? new List<SubscriptionRuleInfo>();
    }

    private async Task SaveSqlRuleAsync()
    {
        if (_selectedEntity is null || _selectedEntity.Type != BusEntityType.Subscription || string.IsNullOrWhiteSpace(_selectedEntity.TopicName))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_ruleName))
        {
            _ruleOperationError = "Rule name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_ruleSqlFilterExpression))
        {
            _ruleOperationError = "SQL filter expression is required.";
            return;
        }

        _updatingRules = true;
        _ruleOperationError = null;

        try
        {
            using var cts = new CancellationTokenSource(AdminOperationTimeout);
            await EntityManager.UpsertSubscriptionSqlRuleAsync(
                _selectedEntity.TopicName,
                _selectedEntity.Name,
                _ruleName.Trim(),
                _ruleSqlFilterExpression.Trim(),
                cts.Token);

            ToastService.ShowSuccess($"Rule '{_ruleName.Trim()}' saved successfully.");
            _ruleName = string.Empty;
            _ruleSqlFilterExpression = string.Empty;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _ruleOperationError = ex.Message;
            Logger.LogError(ex, "Failed to save subscription rule");
        }
        finally
        {
            _updatingRules = false;
        }
    }

    private async Task DeleteRuleAsync(string ruleName)
    {
        if (_selectedEntity is null || _selectedEntity.Type != BusEntityType.Subscription || string.IsNullOrWhiteSpace(_selectedEntity.TopicName))
        {
            return;
        }

        _updatingRules = true;
        _ruleOperationError = null;

        try
        {
            using var cts = new CancellationTokenSource(AdminOperationTimeout);
            await EntityManager.DeleteSubscriptionRuleAsync(
                _selectedEntity.TopicName,
                _selectedEntity.Name,
                ruleName,
                cts.Token);

            ToastService.ShowSuccess($"Rule '{ruleName}' deleted successfully.");
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _ruleOperationError = ex.Message;
            Logger.LogError(ex, "Failed to delete subscription rule");
        }
        finally
        {
            _updatingRules = false;
        }
    }

    public void Dispose() { }
}
