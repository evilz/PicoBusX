    private async Task SubmitDeleteEntityAsync()
    {
        if (_selectedEntity is null) return;
        _deletingEntity = true;
        _deleteEntityError = null;
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            switch (_selectedEntity.Type)
            {
                case BusEntityType.Queue:
                    await EntityManager.DeleteQueueAsync(_selectedEntity.Name, cts.Token);
                    break;
                case BusEntityType.Topic:
                    await EntityManager.DeleteTopicAsync(_selectedEntity.Name, cts.Token);
                    break;
                case BusEntityType.Subscription:
                    await EntityManager.DeleteSubscriptionAsync(_selectedEntity.TopicName!, _selectedEntity.Name, cts.Token);
                    break;
            }
            ToastService.ShowSuccess($"{_selectedEntity.Type} '{_selectedEntity.Name}' deleted successfully!");
            _selectedEntity = null;
            CloseDeleteDialog();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _deleteEntityError = ex.Message;
            Logger.LogError(ex, "Failed to delete entity");
        }
        finally
        {
            _deletingEntity = false;
        }
    }

    private void RestoreSelectionAfterReload()
    {
        if (_selectedEntity is null)
        {
            return;
        }

        var queueExists = _selectedEntity.Type == BusEntityType.Queue && _queues.Any(q => q.Name == _selectedEntity.Name);
        var topicExists = _selectedEntity.Type == BusEntityType.Topic && _topics.Any(t => t.Name == _selectedEntity.Name);
        var subscriptionExists = _selectedEntity.Type == BusEntityType.Subscription &&
                                 _topics.Any(t => t.Name == _selectedEntity.TopicName && t.Subscriptions.Any(s => s.Name == _selectedEntity.Name));

        if (!queueExists && !topicExists && !subscriptionExists)
        {
            _selectedEntity = null;
            _activeTab = "details";
            _browsedMessages.Clear();
            _dlqMessages.Clear();
            _scheduledMessages.Clear();
        }
    }

