@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Azure.Messaging.ServiceBus.Administration
@inject NavigationManager NavigationManager
@implements IDisposable
@inject IExplorerService Explorer
@inject MessageSenderService Sender
@inject MessageBrowserService Browser
@inject EntityManagementService EntityManager
@inject Microsoft.Extensions.Options.IOptions<ServiceBusConnectionOptions> BusOptions
@inject ServiceBusClientFactory Factory
@inject NavigationManager Nav
@inject ILogger<Home> Logger
@inject IToastService ToastService

<PageTitle>PicoBusX – Azure Service Bus Explorer</PageTitle>

<div class="dashboard">
    <!-- Left panel: Tree View -->
    <div class="panel-tree">
        <BusTreeView
            Queues="@_queues" 
            Topics="@_topics" 
            OnEntitySelected="HandleEntitySelected"
            IsLoading="@_loading"
            ErrorMessage="@_loadError"
            WarningMessage="@_loadWarning" />
        <div class="tree-actions">
            <FluentButton Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size16.Add())"
                          OnClick="OpenCreateDialog"
                          Style="width: 100%; margin-bottom: 0.4rem;">
                New Entity
            </FluentButton>
            <FluentButton Appearance="Appearance.Stealth" 
                          IconStart="@(new Icons.Regular.Size16.ArrowSync())"
                          OnClick="LoadDataAsync"
                          Disabled="@_loading"
                          Style="width: 100%;">
                @if (_loading) { <span>Loading…</span> } else { <span>Refresh</span> }
            </FluentButton>
        </div>
    </div>

    <!-- Right panel: Details + Send + Peek -->
    <div class="panel-main">
        @if (_selectedEntity is null)
        {
            <div class="empty-state">
                <div class="empty-icon">🚌</div>
                <h2>PicoBusX</h2>
                @if (!Factory.IsConfigured)
                {
                    <p>No Azure Service Bus connection is configured.</p>
                    <div style="margin-top: 1.25rem;">
                        <FluentButton Appearance="Appearance.Accent"
                                      IconStart="@(new Icons.Regular.Size20.Settings())"
                                      OnClick="@(() => Nav.NavigateTo("/settings"))">
                            Configure Connection
                        </FluentButton>
                    </div>
                }
                else
                {
                    <p>Select a queue, topic, or subscription from the tree to get started.</p>
                    @if (!string.IsNullOrEmpty(_connectionStatus))
                    {
                        <FluentBadge Appearance="@(_isConnected ? Appearance.Accent : Appearance.Neutral)"
                                     Style="margin-top: 1rem; font-size: 0.875rem; padding: 0.5rem 1rem;">
                            @(_isConnected ? "✅ Connected" : "❌ Not Connected") — @_connectionStatus
                        </FluentBadge>
                    }
                }
            </div>
        }
        else
        {
            <div class="entity-header">
                <FluentBadge Appearance="Appearance.Accent" 
                             BackgroundColor="@GetEntityColor(_selectedEntity.Type)"
                             Color="white">
                    @_selectedEntity.Type
                </FluentBadge>
                <h2 style="margin: 0; font-size: 1.3rem;">@_selectedEntity.Name</h2>
                @if (_selectedEntity.TopicName is not null)
                {
                    <span class="entity-parent">under @_selectedEntity.TopicName</span>
                }
                <FluentButton Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Edit())"
                              OnClick="OpenEditDialog"
                              Style="margin-left: auto;"
                              Title="Edit this entity">
                    Edit
                </FluentButton>
                <FluentButton Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Delete())"
                              OnClick="OpenDeleteDialog"
                              Style="color: #dc2626; border-color: #dc2626;"
                              Title="Delete this entity">
                    Delete
                </FluentButton>
            </div>

            <FluentTabs ActiveTabId="@_activeTab" OnTabChange="HandleTabChange">
                <FluentTab Id="details" Label="Details" Icon="@(new Icons.Regular.Size16.List())">
                    <EntityDetailsPanel Entity="@_selectedEntity" Queues="@_queues" Topics="@_topics" />
                </FluentTab>
                @if (_selectedEntity.Type == BusEntityType.Subscription)
                {
                    var rules = GetSelectedSubscriptionRules();

                    <FluentTab Id="rules" Label="Rules & Filters">
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                            <FluentCard Style="padding: 1rem;">
                                <FluentLabel Weight="FontWeight.Bold" Style="display: block; margin-bottom: 0.5rem;">
                                    Subscription rules
                                </FluentLabel>

                                @if (rules.Count == 0)
                                {
                                    <FluentMessageBar Intent="MessageIntent.Info">No rules found for this subscription.</FluentMessageBar>
                                }
                                else
                                {
                                    <table class="details-table">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Filter Type</th>
                                                <th>Filter</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var rule in rules)
                                            {
                                                <tr>
                                                    <td>@rule.Name</td>
                                                    <td>@rule.FilterType</td>
                                                    <td>@rule.FilterExpression</td>
                                                    <td>
                                                        <FluentButton Appearance="Appearance.Stealth"
                                                                      Disabled="@_updatingRules"
                                                                      OnClick="@(() => DeleteRuleAsync(rule.Name))">
                                                            Delete
                                                        </FluentButton>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            </FluentCard>

                            <FluentCard Style="padding: 1rem;">
                                <FluentLabel Weight="FontWeight.Bold" Style="display: block; margin-bottom: 0.5rem;">
                                    Add or update SQL rule
                                </FluentLabel>
                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                    <FluentTextField Label="Rule Name"
                                                     @bind-Value="_ruleName"
                                                     Placeholder="$Default"
                                                     Style="width: 100%;" />
                                    <FluentTextArea Label="SQL Filter Expression"
                                                    @bind-Value="_ruleSqlFilterExpression"
                                                    Placeholder="sys.Label = 'important'"
                                                    Rows="3"
                                                    Style="width: 100%;" />
                                    @if (!string.IsNullOrWhiteSpace(_ruleOperationError))
                                    {
                                        <FluentMessageBar Intent="MessageIntent.Error">@_ruleOperationError</FluentMessageBar>
                                    }
                                    <FluentButton Appearance="Appearance.Accent"
                                                  Disabled="@_updatingRules"
                                                  OnClick="SaveSqlRuleAsync"
                                                  Style="width: fit-content;">
                                        @if (_updatingRules) { <span>Saving…</span> } else { <span>Save Rule</span> }
                                    </FluentButton>
                                </FluentStack>
                            </FluentCard>
                        </FluentStack>
                    </FluentTab>
                }
                @if (_selectedEntity.Type != BusEntityType.Topic)
                {
                    <FluentTab Id="send" Label="Send Message" Icon="@(new Icons.Regular.Size16.Send())">
                        <JsonMessageEditor 
                            Destination="@_selectedEntity.EntityPath"
                            OnSend="HandleSendMessage"
                            IsSending="@_sending"
                            SendResult="@_sendResult"
                            SendError="@_sendError" />
                    </FluentTab>
                    <FluentTab Id="peek" Label="Peek / Read" Icon="@(new Icons.Regular.Size16.Eye())">
                        <PeekReadPanel 
                            EntityPath="@_selectedEntity.EntityPath"
                            DefaultMaxCount="@BusOptions.Value.EntityMaxPeek"
                            OnPeek="HandlePeekAsync"
                            OnReceive="HandleReceiveAsync"
                            OnSettle="HandleSettleAsync"
                            Messages="@_browsedMessages"
                            IsBusy="@_browsing"
                            HasMore="@_hasMoreMessages"
                            ErrorMessage="@_browseError" />
                    </FluentTab>
                    <FluentTab Id="dlq" Label="Dead Letter" Icon="@(new Icons.Regular.Size16.Warning())">
                        <DlqPanel
                            EntityPath="@_selectedEntity.EntityPath"
                            DefaultMaxCount="@BusOptions.Value.EntityMaxPeek"
                            OnPeek="HandleDlqPeekAsync"
                            OnResubmit="HandleDlqResubmitAsync"
                            OnBulkResubmit="HandleDlqBulkResubmitAsync"
                            OnBulkRemove="HandleDlqBulkRemoveAsync"
                            Messages="@_dlqMessages"
                            IsBusy="@_dlqBusy"
                            HasMore="@_hasMoreDlqMessages"
                            ErrorMessage="@_dlqError" />
                    </FluentTab>
                }
                else
                {
                    <FluentTab Id="send" Label="Send to Topic" Icon="@(new Icons.Regular.Size16.Send())">
                        <JsonMessageEditor 
                            Destination="@_selectedEntity.EntityPath"
                            OnSend="HandleSendMessage"
                            IsSending="@_sending"
                            SendResult="@_sendResult"
                            SendError="@_sendError" />
                    </FluentTab>
                }
                @if (CanManageScheduledMessages())
                {
                    <FluentTab Id="scheduled" Label="Scheduled" Icon="@(new Icons.Regular.Size16.Clock())">
                        <ScheduledPanel
                            EntityPath="@_selectedEntity.EntityPath"
                            DefaultMaxCount="@BusOptions.Value.EntityMaxPeek"
                            OnPeek="HandleScheduledPeekAsync"
                            OnCancel="HandleScheduledCancelAsync"
                            Messages="@_scheduledMessages"
                            IsBusy="@_scheduledBusy"
                            HasMore="@_hasMoreScheduledMessages"
                            ErrorMessage="@_scheduledError" />
                    </FluentTab>
                }
            </FluentTabs>
        }
    </div>
</div>

<!-- Create Entity Dialog -->
<FluentDialog @ref="_createDialog"
              Hidden="@_createDialogHidden"
              Modal="true"
              TrapFocus="true"
              PreventScroll="true"
              @ondialogdismiss="CloseCreateDialog">
    <FluentDialogHeader ShowDismiss="true">
        <strong>Create New Entity</strong>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; padding: 0.5rem 0; min-width: 320px;">
            <FluentSelect TOption="string"
                          Label="Entity Type"
                          @bind-Value="_newEntityType"
                          Style="width: 100%;">
                <FluentOption TOption="string" Value="queue">Queue</FluentOption>
                <FluentOption TOption="string" Value="topic">Topic</FluentOption>
                <FluentOption TOption="string" Value="subscription">Subscription</FluentOption>
            </FluentSelect>

            @if (_newEntityType == "subscription")
            {
                <FluentTextField Label="Topic Name"
                                 @bind-Value="_newTopicName"
                                 Placeholder="existing-topic-name"
                                 Style="width: 100%;" />
            }

            <FluentTextField Label="@(_newEntityType == "subscription" ? "Subscription Name" : "Name")"
                             @bind-Value="_newEntityName"
                             Placeholder="my-entity-name"
                             Style="width: 100%;" />

            <FluentDivider />
            <FluentLabel Typography="Typography.PaneHeader">Advanced Options</FluentLabel>

            <FluentTextField Label="Default Message TTL (hh:mm:ss)"
                             @bind-Value="_newDefaultMessageTtl"
                             Placeholder="e.g. 14.00:00:00"
                             Style="width: 100%;" />

            @if (_newEntityType is "queue" or "subscription")
            {
                <FluentTextField Label="Max Delivery Count"
                                 @bind-Value="_newMaxDeliveryCount"
                                 Placeholder="e.g. 10"
                                 Style="width: 100%;" />

                <FluentSelect TOption="string"
                              Label="Requires Session"
                              @bind-Value="_newRequiresSession"
                              Style="width: 100%;">
                    <FluentOption TOption="string" Value="default">Use Service Bus default</FluentOption>
                    <FluentOption TOption="string" Value="true">Yes</FluentOption>
                    <FluentOption TOption="string" Value="false">No</FluentOption>
                </FluentSelect>

                <FluentTextField Label="Forward To"
                                 @bind-Value="_newForwardTo"
                                 Placeholder="optional-forward-entity"
                                 Style="width: 100%;" />

                <FluentTextField Label="Forward Dead-Lettered Messages To"
                                 @bind-Value="_newForwardDeadLetteredMessagesTo"
                                 Placeholder="optional-forward-dlq-entity"
                                 Style="width: 100%;" />
            }

            @if (_newEntityType is "queue" or "topic")
            {
                <FluentSelect TOption="string"
                              Label="Enable Partitioning"
                              @bind-Value="_newEnablePartitioning"
                              Style="width: 100%;">
                    <FluentOption TOption="string" Value="default">Use Service Bus default</FluentOption>
                    <FluentOption TOption="string" Value="true">Yes</FluentOption>
                    <FluentOption TOption="string" Value="false">No</FluentOption>
                </FluentSelect>
            }

            @if (!string.IsNullOrEmpty(_createEntityError))
            {
                <FluentMessageBar Intent="MessageIntent.Error">@_createEntityError</FluentMessageBar>
            }
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="SubmitCreateEntityAsync"
                      Disabled="@_creatingEntity">
            @if (_creatingEntity) { <span>Creating…</span> } else { <span>Create</span> }
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="CloseCreateDialog">Cancel</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

<!-- Edit Entity Dialog -->
<FluentDialog @ref="_editDialog"
              Hidden="@_editDialogHidden"
              Modal="true"
              TrapFocus="true"
              PreventScroll="true"
              @ondialogdismiss="CloseEditDialog">
    <FluentDialogHeader ShowDismiss="true">
        <strong>Edit Entity Settings</strong>
    </FluentDialogHeader>
    <FluentDialogBody>
        @if (_selectedEntity is null)
        {
            <FluentMessageBar Intent="MessageIntent.Warning">No entity selected.</FluentMessageBar>
        }
        else
        {
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; padding: 0.5rem 0; min-width: 340px;">
                @if (_selectedEntity.Type == BusEntityType.Queue || _selectedEntity.Type == BusEntityType.Subscription)
                {
                    <FluentTextField Label="Lock Duration (c format)"
                                     @bind-Value="_editForm.LockDuration"
                                     Placeholder="00:01:00"
                                     Style="width: 100%;" />

                    <FluentTextField Label="Max Delivery Count"
                                     @bind-Value="_editForm.MaxDeliveryCount"
                                     Placeholder="10"
                                     Style="width: 100%;" />
                }

                <FluentTextField Label="Default Message TTL (c format)"
                                 @bind-Value="_editForm.DefaultMessageTimeToLive"
                                 Placeholder="14.00:00:00"
                                 Style="width: 100%;" />

                <FluentTextField Label="Auto Delete On Idle (c format)"
                                 @bind-Value="_editForm.AutoDeleteOnIdle"
                                 Placeholder="10675199.02:48:05.4775807"
                                 Style="width: 100%;" />

                <FluentCheckbox Label="Enable batched operations" @bind-Value="_editForm.EnableBatchedOperations" />

                @if (_selectedEntity.Type == BusEntityType.Topic)
                {
                    <FluentCheckbox Label="Support ordering" @bind-Value="_editForm.SupportOrdering" />
                }
                else
                {
                    <FluentCheckbox Label="Dead-letter on message expiration" @bind-Value="_editForm.DeadLetteringOnMessageExpiration" />
                    <FluentTextField Label="Forward To"
                                     @bind-Value="_editForm.ForwardTo"
                                     Placeholder="target-entity"
                                     Style="width: 100%;" />
                    <FluentTextField Label="Forward Dead-Lettered Messages To"
                                     @bind-Value="_editForm.ForwardDeadLetteredMessagesTo"
                                     Placeholder="target-dead-letter-entity"
                                     Style="width: 100%;" />

                    @if (_selectedEntity.Type == BusEntityType.Subscription)
                    {
                        <FluentCheckbox Label="Dead-letter on filter evaluation exceptions"
                                        @bind-Value="_editForm.DeadLetteringOnFilterEvaluationExceptions" />
                    }
                }

                @if (!string.IsNullOrEmpty(_editEntityError))
                {
                    <FluentMessageBar Intent="MessageIntent.Error">@_editEntityError</FluentMessageBar>
                }
            </FluentStack>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="SubmitUpdateEntityAsync"
                      Disabled="@(_updatingEntity || _selectedEntity is null)">
            @if (_updatingEntity) { <span>Saving…</span> } else { <span>Save</span> }
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="CloseEditDialog">Cancel</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

<!-- Delete Entity Dialog -->
<FluentDialog @ref="_deleteDialog"
              Hidden="@_deleteDialogHidden"
              Modal="true"
              TrapFocus="true"
              PreventScroll="true"
              @ondialogdismiss="CloseDeleteDialog">
    <FluentDialogHeader ShowDismiss="true">
        <strong>Delete Entity</strong>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem; padding: 0.5rem 0;">
            <p>Are you sure you want to delete <strong>@_selectedEntity?.Name</strong>?</p>
            <p style="color: #dc2626; font-size: 0.85rem;">⚠️ This action cannot be undone. All messages will be lost.</p>
            @if (!string.IsNullOrEmpty(_deleteEntityError))
            {
                <FluentMessageBar Intent="MessageIntent.Error">@_deleteEntityError</FluentMessageBar>
            }
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="SubmitDeleteEntityAsync"
                      Disabled="@_deletingEntity"
                      Style="background: #dc2626;">
            @if (_deletingEntity) { <span>Deleting…</span> } else { <span>Delete</span> }
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="CloseDeleteDialog">Cancel</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private sealed class EntityEditFormState
    {
        public string LockDuration { get; set; } = string.Empty;
        public string MaxDeliveryCount { get; set; } = string.Empty;
        public string DefaultMessageTimeToLive { get; set; } = string.Empty;
        public string AutoDeleteOnIdle { get; set; } = string.Empty;
        public bool EnableBatchedOperations { get; set; }
        public bool SupportOrdering { get; set; }
        public bool DeadLetteringOnMessageExpiration { get; set; }
        public bool DeadLetteringOnFilterEvaluationExceptions { get; set; }
        public string? ForwardTo { get; set; }
        public string? ForwardDeadLetteredMessagesTo { get; set; }
    }

    private static readonly TimeSpan AdminOperationTimeout = TimeSpan.FromSeconds(30);
    private static readonly TimeSpan DlqSingleOperationTimeout = TimeSpan.FromSeconds(30);
    private static readonly TimeSpan DlqBulkOperationTimeout = TimeSpan.FromSeconds(60);

    private List<QueueInfo> _queues = new();
    private List<TopicInfo> _topics = new();
    [SupplyParameterFromQuery(Name = "name")]
    [Parameter]
    public string? EntityName { get; set; }

    [SupplyParameterFromQuery(Name = "type")]
    [Parameter]
    public string? EntityType { get; set; }

    [SupplyParameterFromQuery(Name = "topicName")]
    [Parameter]
    public string? TopicName { get; set; }

    private BusEntity? _selectedEntity;

    protected override async Task OnParametersSetAsync()
    {
        BusEntity? newEntity = null;

        if (EntityName is not null && EntityType is not null)
        {
            if (Enum.TryParse<BusEntityType>(EntityType, ignoreCase: true, out var entityType))
            {
                newEntity = new BusEntity
                {
                    Type = entityType,
                    Name = EntityName,
                    TopicName = TopicName
                };
            }
        }

        var selectionChanged = (_selectedEntity is null) != (newEntity is null)
            || (_selectedEntity is not null && newEntity is not null
                && (_selectedEntity.Type != newEntity.Type
                    || _selectedEntity.Name != newEntity.Name
                    || _selectedEntity.TopicName != newEntity.TopicName));

        if (selectionChanged)
        {
            var previousEntityPath = _selectedEntity?.EntityPath;
            _selectedEntity = newEntity;
            await ResetEntityScopedStateAsync(previousEntityPath);
        }
    }
    private string _activeTab = "details";
    private bool _loading;
    private string? _loadError;
    private string? _loadWarning;
    private bool _isConnected;
    private string _connectionStatus = string.Empty;

    private bool _sending;
    private string? _sendResult;
    private string? _sendError;

    private List<BrowsedMessage> _browsedMessages = new();
    private bool _browsing;
    private bool _hasMoreMessages;
    private string? _browseError;

    private List<BrowsedMessage> _dlqMessages = new();
    private bool _dlqBusy;
    private bool _hasMoreDlqMessages;
    private string? _dlqError;
    private List<BrowsedMessage> _scheduledMessages = new();
    private bool _scheduledBusy;
    private bool _hasMoreScheduledMessages;
    private string? _scheduledError;
    private const string ScheduledQueueOnlyBrowseError = "Scheduled browsing is only available for non-session queues.";
    private const string ScheduledQueueOnlyCancelError = "Scheduled message cancellation is only available for non-session queues.";

    // Create entity dialog state
    private FluentDialog? _createDialog;
    private bool _createDialogHidden = true;
    private string _newEntityType = "queue";
    private string _newEntityName = string.Empty;
    private string? _newTopicName;
    private string? _newDefaultMessageTtl;
    private string? _newMaxDeliveryCount;
    private string _newRequiresSession = "default";
    private string _newEnablePartitioning = "default";
    private string? _newForwardTo;
    private string? _newForwardDeadLetteredMessagesTo;
    private bool _creatingEntity;
    private string? _createEntityError;
    private const int MaxDeliveryCountUpperBound = 2000;

    // Edit entity dialog state
    private FluentDialog? _editDialog;
    private bool _editDialogHidden = true;
    private EntityEditFormState _editForm = new();
    private bool _updatingEntity;
    private string? _editEntityError;

    // Delete entity dialog state
    private FluentDialog? _deleteDialog;
    private bool _deleteDialogHidden = true;
    private bool _deletingEntity;
    private string? _deleteEntityError;
    private bool _updatingRules;
    private string _ruleName = string.Empty;
    private string _ruleSqlFilterExpression = string.Empty;
    private string? _ruleOperationError;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _loadError = null;
        _loadWarning = null;
        _isConnected = false;
        StateHasChanged();

        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            var loadResult = await Explorer.LoadAsync(cts.Token);

            _queues = loadResult.Queues;
            _topics = loadResult.Topics;
            _loadWarning = loadResult.WarningMessage;
            _loadError = loadResult.ErrorMessage;

            RestoreSelectionAfterReload();

            if (loadResult.HasError)
            {
                _connectionStatus = loadResult.ErrorMessage!;
                return;
            }

            if (loadResult.HasWarning)
            {
                _connectionStatus = loadResult.WarningMessage!;
                return;
            }

            _isConnected = true;
            _connectionStatus = $"Loaded {_queues.Count} queues, {_topics.Count} topics";
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            _connectionStatus = ex.Message;
            Logger.LogError(ex, "Failed to load Service Bus data");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleEntitySelected(BusEntity entity)
    {
        var previousEntityPath = _selectedEntity?.EntityPath;
        _selectedEntity = entity;
        NavigationManager.NavigateTo(NavigationManager.GetUriWithQueryParameters("/", new Dictionary<string, object?>
        {
            { "name", entity.Name },
            { "type", entity.Type.ToString() },
            { "topicName", entity.TopicName }
        }));
        await ResetEntityScopedStateAsync(previousEntityPath);
    }

    private async Task ResetEntityScopedStateAsync(string? previousEntityPath = null)
    {
        var previousReset = !string.IsNullOrWhiteSpace(previousEntityPath)
            ? ResetPendingMessagesSafeAsync(previousEntityPath)
            : Task.CompletedTask;

        var currentReset = _selectedEntity is not null
            ? ResetPendingMessagesSafeAsync(_selectedEntity.EntityPath)
            : Task.CompletedTask;

        _activeTab = "details";
        _browsedMessages = new();
        _hasMoreMessages = false;
        _sendResult = null;
        _sendError = null;
        _browseError = null;
        _dlqMessages = new();
        _hasMoreDlqMessages = false;
        _dlqError = null;
        _scheduledMessages = new();
        _hasMoreScheduledMessages = false;
        _scheduledError = null;
        _updatingRules = false;
        _ruleName = string.Empty;
        _ruleSqlFilterExpression = string.Empty;
        _ruleOperationError = null;

        await Task.WhenAll(previousReset, currentReset);
    }

    private async Task ResetPendingMessagesSafeAsync(string entityPath)
    {
        try
        {
            await Browser.ResetPendingMessagesAsync(entityPath);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to reset pending messages for {EntityPath}", SanitizeForLog(entityPath));
        }
    }

    private static string SanitizeForLog(string value)
    {
        return value.Replace("\r", "\\r", StringComparison.Ordinal)
            .Replace("\n", "\\n", StringComparison.Ordinal);
    }

    private void HandleTabChange(FluentTab tab)
    {
        _activeTab = tab.Id ?? "details";
    }

    private async Task HandleSendMessage(SendMessageRequest request)
    {
        _sending = true;
        _sendResult = null;
        _sendError = null;
        StateHasChanged();
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            await Sender.SendMessageAsync(request, cts.Token);
            _sendResult = "Message sent successfully!";
            ToastService.ShowSuccess("Message sent successfully!");
        }
        catch (Exception ex)
        {
            _sendError = ex.Message;
            ToastService.ShowError($"Send failed: {ex.Message}");
            Logger.LogError(ex, "Failed to send message");
        }
        finally
        {
            _sending = false;
        }
    }

    private bool IsSessionEnabled() => _selectedEntity?.Type switch
    {
        BusEntityType.Queue => _queues.FirstOrDefault(q => q.Name == _selectedEntity.Name)?.RequiresSession ?? false,
        BusEntityType.Subscription => _topics
            .FirstOrDefault(t => t.Name == _selectedEntity.TopicName)
            ?.Subscriptions.FirstOrDefault(s => s.Name == _selectedEntity.Name)
            ?.RequiresSession ?? false,
        _ => false
    };

    private bool CanManageScheduledMessages()
        => _selectedEntity?.Type == BusEntityType.Queue && !IsSessionEnabled();

    private async Task HandlePeekAsync((string entityPath, int maxCount, long? fromSequenceNumber) args)
    {
        if (!args.fromSequenceNumber.HasValue)
        {
            _browsedMessages = new();
            _hasMoreMessages = false;
        }
        await ExecutePeekAsync(
            ct => IsSessionEnabled()
                ? MessageBrowserService.PeekSessionMessagesAsync(Factory.GetClient(), args.entityPath, args.maxCount, ct)
                : Browser.PeekMessagesAsync(args.entityPath, args.maxCount, args.fromSequenceNumber, ct),
            busy => _browsing = busy,
            err => _browseError = err,
            batch =>
            {
                _browsedMessages = args.fromSequenceNumber.HasValue ? _browsedMessages.Concat(batch).ToList() : batch;
                _hasMoreMessages = !IsSessionEnabled() && batch.Count >= args.maxCount;
            },
            ex => Logger.LogError(ex, "Failed to peek messages"));
    }

    private async Task HandleReceiveAsync((string entityPath, int maxCount) args)
    {
        _browsing = true;
        _browseError = null;
        _browsedMessages = new();
        StateHasChanged();
        try
        {
            using var cts = new CancellationTokenSource(DlqSingleOperationTimeout);
            _browsedMessages = IsSessionEnabled()
                ? await Browser.ReceiveSessionWithLockAsync(args.entityPath, args.maxCount, cts.Token)
                : await Browser.ReceiveWithLockAsync(args.entityPath, args.maxCount, cts.Token);
        }
        catch (Exception ex)
        {
            _browseError = ex.Message;
            Logger.LogError(ex, "Failed to receive messages");
        }
        finally
        {
            _browsing = false;
        }
    }

    private async Task HandleSettleAsync((string lockToken, MessageSettlementAction action) args)
    {
        try
        {
            using var cts = new CancellationTokenSource(DlqSingleOperationTimeout);
            var settled = await Browser.SettleReceivedMessageAsync(args.lockToken, args.action, cts.Token);
            if (!settled)
            {
                ToastService.ShowInfo("Message lock expired or is no longer available.");
            }
            else
            {
                ToastService.ShowSuccess($"{args.action} completed.");
            }

            _browsedMessages = _browsedMessages.Where(m => m.LockToken != args.lockToken).ToList();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Settlement failed: {ex.Message}");
            Logger.LogError(ex, "Failed to settle message with action {Action}", args.action);
        }
    }

    private async Task HandleDlqPeekAsync((string entityPath, int maxCount, long? fromSequenceNumber) args)
    {
        if (!args.fromSequenceNumber.HasValue)
        {
            _dlqMessages = new();
            _hasMoreDlqMessages = false;
        }
        await ExecutePeekAsync(
            ct => Browser.PeekDeadLetterAsync(args.entityPath, args.maxCount, args.fromSequenceNumber, ct),
            busy => _dlqBusy = busy,
            err => _dlqError = err,
            batch =>
            {
                _dlqMessages = args.fromSequenceNumber.HasValue ? _dlqMessages.Concat(batch).ToList() : batch;
                _hasMoreDlqMessages = batch.Count >= args.maxCount;
            },
            ex => Logger.LogError(ex, "Failed to peek DLQ messages"));
    }

    private async Task ExecutePeekAsync(
        Func<CancellationToken, Task<List<BrowsedMessage>>> fetchFunc,
        Action<bool> setBusy,
        Action<string?> setError,
        Action<List<BrowsedMessage>> onSuccess,
        Action<Exception> logError)
    {
        setBusy(true);
        setError(null);
        StateHasChanged();
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            var batch = await fetchFunc(cts.Token);
            onSuccess(batch);
        }
        catch (Exception ex)
        {
            setError(ex.Message);
            logError(ex);
        }
        finally
        {
            setBusy(false);
        }
    }

    private async Task HandleDlqResubmitAsync(long sequenceNumber)
    {
        try
        {
            using var cts = new CancellationTokenSource(DlqSingleOperationTimeout);
            await Browser.ResubmitDeadLetterAsync(_selectedEntity!.EntityPath, sequenceNumber, cts.Token);
            ToastService.ShowSuccess($"Message #{sequenceNumber} resubmitted successfully!");
            _dlqMessages = _dlqMessages.Where(m => m.SequenceNumber != sequenceNumber).ToList();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Resubmit failed: {ex.Message}");
            Logger.LogError(ex, "Failed to resubmit DLQ message");
        }
    }

    private async Task HandleDlqBulkResubmitAsync(IReadOnlyList<long> sequenceNumbers)
    {
        if (sequenceNumbers.Count == 0 || _selectedEntity is null)
        {
            return;
        }

        try
        {
            using var cts = new CancellationTokenSource(DlqBulkOperationTimeout);
            var resubmitted = await Browser.ResubmitDeadLettersAsync(_selectedEntity.EntityPath, sequenceNumbers, cts.Token);
            var resubmittedSet = resubmitted.ToHashSet();
            _dlqMessages = _dlqMessages.Where(m => !resubmittedSet.Contains(m.SequenceNumber)).ToList();
            if (resubmitted.Count == sequenceNumbers.Count)
            {
                ToastService.ShowSuccess($"{resubmitted.Count} dead-letter message(s) resubmitted successfully.");
            }
            else
            {
                ToastService.ShowWarning($"{resubmitted.Count} of {sequenceNumbers.Count} selected dead-letter message(s) were resubmitted.");
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Bulk resubmit failed: {ex.Message}");
            Logger.LogError(ex, "Failed to bulk resubmit DLQ messages");
        }
    }

    private async Task HandleDlqBulkRemoveAsync(IReadOnlyList<long> sequenceNumbers)
    {
        if (sequenceNumbers.Count == 0 || _selectedEntity is null)
        {
            return;
        }

        try
        {
            using var cts = new CancellationTokenSource(DlqBulkOperationTimeout);
            var removed = await Browser.RemoveDeadLettersAsync(_selectedEntity.EntityPath, sequenceNumbers, cts.Token);
            var removedSet = removed.ToHashSet();
            _dlqMessages = _dlqMessages.Where(m => !removedSet.Contains(m.SequenceNumber)).ToList();
            if (removed.Count == sequenceNumbers.Count)
            {
                ToastService.ShowSuccess($"{removed.Count} dead-letter message(s) removed successfully.");
            }
            else
            {
                ToastService.ShowWarning($"{removed.Count} of {sequenceNumbers.Count} selected dead-letter message(s) were removed.");
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Bulk remove failed: {ex.Message}");
            Logger.LogError(ex, "Failed to bulk remove DLQ messages");
        }
    }

    private void OpenCreateDialog()
    {
        _newEntityType = "queue";
        _newEntityName = string.Empty;
        _newTopicName = null;
        _newDefaultMessageTtl = null;
        _newMaxDeliveryCount = null;
        _newRequiresSession = "default";
        _newEnablePartitioning = "default";
        _newForwardTo = null;
        _newForwardDeadLetteredMessagesTo = null;
        _createEntityError = null;
        _createDialogHidden = false;
    }

    private void CloseCreateDialog() => _createDialogHidden = true;

    private async Task SubmitCreateEntityAsync()
    {
        if (string.IsNullOrWhiteSpace(_newEntityName))
        {
            _createEntityError = "Name is required.";
            return;
        }
        if (_newEntityType == "subscription" && string.IsNullOrWhiteSpace(_newTopicName))
        {
            _createEntityError = "Topic Name is required for subscriptions.";
            return;
        }
        if (!TryParseOptionalTimeSpan(_newDefaultMessageTtl, out _))
        {
            _createEntityError = "Default Message TTL must be a valid TimeSpan (for example, 00:30:00 or 14.00:00:00).";
            return;
        }
        if (_newEntityType is "queue" or "subscription"
            && !TryParseOptionalPositiveInt(_newMaxDeliveryCount, out _))
        {
            _createEntityError = $"Max Delivery Count must be a whole number between 1 and {MaxDeliveryCountUpperBound}.";
            return;
        }
        _creatingEntity = true;
        _createEntityError = null;
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            switch (_newEntityType)
            {
                case "queue":
                    var queueOptions = BuildQueueOptions(_newEntityName.Trim());
                    await EntityManager.CreateQueueAsync(queueOptions, cts.Token);
                    break;
                case "topic":
                    var topicOptions = BuildTopicOptions(_newEntityName.Trim());
                    await EntityManager.CreateTopicAsync(topicOptions, cts.Token);
                    break;
                case "subscription":
                    var subscriptionOptions = BuildSubscriptionOptions(_newTopicName!.Trim(), _newEntityName.Trim());
                    await EntityManager.CreateSubscriptionAsync(subscriptionOptions, cts.Token);
                    break;
            }
            ToastService.ShowSuccess($"{char.ToUpper(_newEntityType[0])}{_newEntityType[1..]} '{_newEntityName}' created successfully!");
            CloseCreateDialog();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _createEntityError = ex.Message;
            Logger.LogError(ex, "Failed to create entity");
        }
        finally
        {
            _creatingEntity = false;
        }
    }

    private async Task HandleScheduledPeekAsync((string entityPath, int maxCount, long? fromSequenceNumber) args)
    {
        if (!CanManageScheduledMessages())
        {
            _scheduledError = ScheduledQueueOnlyBrowseError;
            return;
        }

        if (!args.fromSequenceNumber.HasValue)
        {
            _scheduledMessages = new();
            _hasMoreScheduledMessages = false;
        }

        await ExecutePeekAsync(
            ct => Browser.PeekScheduledMessagesAsync(args.entityPath, args.maxCount, args.fromSequenceNumber, ct),
            busy => _scheduledBusy = busy,
            err => _scheduledError = err,
            batch =>
            {
                _scheduledMessages = args.fromSequenceNumber.HasValue ? _scheduledMessages.Concat(batch).ToList() : batch;
                _hasMoreScheduledMessages = batch.Count >= args.maxCount;
            },
            ex => Logger.LogError(ex, "Failed to peek scheduled messages"));
    }

    private async Task HandleScheduledCancelAsync(long sequenceNumber)
    {
        if (!CanManageScheduledMessages())
        {
            _scheduledError = ScheduledQueueOnlyCancelError;
            return;
        }

        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
