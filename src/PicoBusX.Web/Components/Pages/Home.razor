        return true;
    }

    private static bool TryParseDuration(string? value, string fieldName, out TimeSpan parsed, out string? error)
    {
        if (TimeSpan.TryParse(value, out parsed))
        {
            error = null;
            return true;
        }

        error = $"{fieldName} must be a valid duration (example: 00:01:00).";
        return false;
    }

    private static bool TryParsePositiveInt(string? value, string fieldName, out int parsed, out string? error)
    {
        if (int.TryParse(value, out parsed) && parsed > 0)
        {
            error = null;
            return true;
        }

        error = $"{fieldName} must be a positive number.";
        return false;
    }

    private static string? NormalizeOptionalText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

