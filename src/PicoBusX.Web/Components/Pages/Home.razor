    private CreateQueueOptions BuildQueueOptions(string queueName)
    {
        var options = new CreateQueueOptions(queueName);
        ApplyDefaultMessageTtlIfSpecified(ttl => options.DefaultMessageTimeToLive = ttl);
        ApplyPartitioningIfSpecified(enable => options.EnablePartitioning = enable);
        ApplySharedQueueAndSubscriptionOptions(
            maxDeliveryCount => options.MaxDeliveryCount = maxDeliveryCount,
            requiresSession => options.RequiresSession = requiresSession,
            forwardTo => options.ForwardTo = forwardTo,
            forwardDeadLetteredMessagesTo => options.ForwardDeadLetteredMessagesTo = forwardDeadLetteredMessagesTo);
        return options;
    }

    private CreateTopicOptions BuildTopicOptions(string topicName)
    {
        var options = new CreateTopicOptions(topicName);
        ApplyDefaultMessageTtlIfSpecified(ttl => options.DefaultMessageTimeToLive = ttl);
        ApplyPartitioningIfSpecified(enable => options.EnablePartitioning = enable);
        return options;
    }

    private CreateSubscriptionOptions BuildSubscriptionOptions(string topicName, string subscriptionName)
    {
        var options = new CreateSubscriptionOptions(topicName, subscriptionName);
        ApplyDefaultMessageTtlIfSpecified(ttl => options.DefaultMessageTimeToLive = ttl);
        ApplySharedQueueAndSubscriptionOptions(
            maxDeliveryCount => options.MaxDeliveryCount = maxDeliveryCount,
            requiresSession => options.RequiresSession = requiresSession,
            forwardTo => options.ForwardTo = forwardTo,
            forwardDeadLetteredMessagesTo => options.ForwardDeadLetteredMessagesTo = forwardDeadLetteredMessagesTo);
        return options;
    }

    private void ApplySharedQueueAndSubscriptionOptions(
        Action<int> setMaxDeliveryCount,
        Action<bool> setRequiresSession,
        Action<string> setForwardTo,
        Action<string> setForwardDeadLetteredMessagesTo)
    {
        if (TryParseOptionalPositiveInt(_newMaxDeliveryCount, out var maxDeliveryCount)
            && maxDeliveryCount is not null)
        {
            setMaxDeliveryCount(maxDeliveryCount.Value);
        }

        if (TryParseExplicitBool(_newRequiresSession, out var requiresSession))
        {
            setRequiresSession(requiresSession);
        }

        if (!string.IsNullOrWhiteSpace(_newForwardTo))
        {
            setForwardTo(_newForwardTo.Trim());
        }

        if (!string.IsNullOrWhiteSpace(_newForwardDeadLetteredMessagesTo))
        {
            setForwardDeadLetteredMessagesTo(_newForwardDeadLetteredMessagesTo.Trim());
        }
    }

    private void ApplyDefaultMessageTtlIfSpecified(Action<TimeSpan> setDefaultMessageTtl)
    {
        if (TryParseOptionalTimeSpan(_newDefaultMessageTtl, out var ttl)
            && ttl is not null)
        {
            setDefaultMessageTtl(ttl.Value);
        }
    }

    private void ApplyPartitioningIfSpecified(Action<bool> setEnablePartitioning)
    {
        if (TryParseExplicitBool(_newEnablePartitioning, out var enablePartitioning))
        {
            setEnablePartitioning(enablePartitioning);
        }
    }

    private static bool TryParseExplicitBool(string? value, out bool parsed)
    {
        parsed = false;
        return value is "true" or "false" && bool.TryParse(value, out parsed);
    }

    private static bool TryParseOptionalTimeSpan(string? value, out TimeSpan? parsed)
    {
        parsed = null;
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if (!TimeSpan.TryParse(value, out var timeSpan))
        {
            return false;
        }

        parsed = timeSpan;
        return true;
    }

    private static bool TryParseOptionalPositiveInt(string? value, out int? parsed)
    {
        parsed = null;
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if (!int.TryParse(value, out var integer) || integer < 1 || integer > MaxDeliveryCountUpperBound)
        {
            return false;
        }

        parsed = integer;
        return true;
    }

    private void OpenEditDialog()
    {
        if (_selectedEntity is null)
        {
            return;
        }

        _editEntityError = null;

        switch (_selectedEntity.Type)
        {
            case BusEntityType.Queue:
                var queue = _queues.FirstOrDefault(q => q.Name == _selectedEntity.Name);
                if (queue is null)
                {
                    ShowEditUnavailableError("Queue details are unavailable. Refresh and try again.");
                    return;
                }

                _editForm = new EntityEditFormState
                {
                    LockDuration = queue.LockDuration.ToString("c"),
                    MaxDeliveryCount = queue.MaxDeliveryCount.ToString(),
                    DefaultMessageTimeToLive = queue.DefaultMessageTimeToLive.ToString("c"),
                    AutoDeleteOnIdle = queue.AutoDeleteOnIdle.ToString("c"),
                    EnableBatchedOperations = queue.EnableBatchedOperations,
                    DeadLetteringOnMessageExpiration = queue.DeadLetteringOnMessageExpiration,
                    ForwardTo = queue.ForwardTo,
                    ForwardDeadLetteredMessagesTo = queue.ForwardDeadLetteredMessagesTo
                };
                break;

            case BusEntityType.Topic:
                var topic = _topics.FirstOrDefault(t => t.Name == _selectedEntity.Name);
                if (topic is null)
                {
                    ShowEditUnavailableError("Topic details are unavailable. Refresh and try again.");
                    return;
                }

                _editForm = new EntityEditFormState
                {
                    DefaultMessageTimeToLive = topic.DefaultMessageTimeToLive.ToString("c"),
                    AutoDeleteOnIdle = topic.AutoDeleteOnIdle.ToString("c"),
                    EnableBatchedOperations = topic.EnableBatchedOperations,
                    SupportOrdering = topic.SupportOrdering
                };
                break;

            case BusEntityType.Subscription:
                var selectedTopic = _topics.FirstOrDefault(t => t.Name == _selectedEntity.TopicName);
                var subscription = selectedTopic?.Subscriptions.FirstOrDefault(s => s.Name == _selectedEntity.Name);
                if (subscription is null)
                {
                    ShowEditUnavailableError("Subscription details are unavailable. Refresh and try again.");
                    return;
                }

                _editForm = new EntityEditFormState
                {
                    LockDuration = subscription.LockDuration.ToString("c"),
                    MaxDeliveryCount = subscription.MaxDeliveryCount.ToString(),
                    DefaultMessageTimeToLive = subscription.DefaultMessageTimeToLive.ToString("c"),
                    AutoDeleteOnIdle = subscription.AutoDeleteOnIdle.ToString("c"),
                    EnableBatchedOperations = subscription.EnableBatchedOperations,
                    DeadLetteringOnMessageExpiration = subscription.DeadLetteringOnMessageExpiration,
                    DeadLetteringOnFilterEvaluationExceptions = subscription.DeadLetteringOnFilterEvaluationExceptions,
                    ForwardTo = subscription.ForwardTo,
                    ForwardDeadLetteredMessagesTo = subscription.ForwardDeadLetteredMessagesTo
                };
                break;
        }

        _editDialogHidden = false;
    }

    private void ShowEditUnavailableError(string message)
    {
        _editEntityError = message;
        _editDialogHidden = true;
        ToastService.ShowError(message);
    }

    private void CloseEditDialog() => _editDialogHidden = true;

    private async Task SubmitUpdateEntityAsync()
    {
        if (_selectedEntity is null)
        {
            return;
        }

        _updatingEntity = true;
        _editEntityError = null;

        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            switch (_selectedEntity.Type)
            {
                case BusEntityType.Queue:
                    if (!TryBuildQueueUpdateOptions(out var queueOptions, out var queueError))
                    {
                        _editEntityError = queueError;
                        return;
                    }

                    await EntityManager.UpdateQueueAsync(_selectedEntity.Name, queueOptions, cts.Token);
                    break;
                case BusEntityType.Topic:
                    if (!TryBuildTopicUpdateOptions(out var topicOptions, out var topicError))
                    {
                        _editEntityError = topicError;
                        return;
                    }

                    await EntityManager.UpdateTopicAsync(_selectedEntity.Name, topicOptions, cts.Token);
                    break;
                case BusEntityType.Subscription:
                    if (_selectedEntity.TopicName is null)
                    {
                        _editEntityError = "A subscription must include a topic name.";
                        return;
                    }

                    if (!TryBuildSubscriptionUpdateOptions(out var subscriptionOptions, out var subscriptionError))
                    {
                        _editEntityError = subscriptionError;
                        return;
                    }

                    await EntityManager.UpdateSubscriptionAsync(_selectedEntity.TopicName, _selectedEntity.Name, subscriptionOptions, cts.Token);
                    break;
            }

            ToastService.ShowSuccess($"{_selectedEntity.Type} '{_selectedEntity.Name}' updated successfully!");
            CloseEditDialog();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _editEntityError = ex.Message;
            Logger.LogError(ex, "Failed to update entity settings");
        }
        finally
        {
            _updatingEntity = false;
        }
    }

    private bool TryBuildQueueUpdateOptions(
        out EntityManagementService.QueueUpdateOptions options,
        out string? error)
    {
        options = default!;
        error = null;

        if (!TryParseDuration(_editForm.LockDuration, "Lock Duration", out var lockDuration, out error)
            || !TryParsePositiveInt(_editForm.MaxDeliveryCount, "Max Delivery Count", out var maxDeliveryCount, out error)
            || !TryParseDuration(_editForm.DefaultMessageTimeToLive, "Default Message TTL", out var defaultMessageTtl, out error)
            || !TryParseDuration(_editForm.AutoDeleteOnIdle, "Auto Delete On Idle", out var autoDeleteOnIdle, out error))
        {
            return false;
        }

        options = new EntityManagementService.QueueUpdateOptions(
            lockDuration,
            maxDeliveryCount,
            defaultMessageTtl,
            autoDeleteOnIdle,
            _editForm.EnableBatchedOperations,
            _editForm.DeadLetteringOnMessageExpiration,
            NormalizeOptionalText(_editForm.ForwardTo),
            NormalizeOptionalText(_editForm.ForwardDeadLetteredMessagesTo));

        return true;
    }

    private bool TryBuildTopicUpdateOptions(
        out EntityManagementService.TopicUpdateOptions options,
        out string? error)
    {
        options = default!;
        error = null;

        if (!TryParseDuration(_editForm.DefaultMessageTimeToLive, "Default Message TTL", out var defaultMessageTtl, out error)
            || !TryParseDuration(_editForm.AutoDeleteOnIdle, "Auto Delete On Idle", out var autoDeleteOnIdle, out error))
        {
            return false;
        }

        options = new EntityManagementService.TopicUpdateOptions(
            defaultMessageTtl,
            autoDeleteOnIdle,
            _editForm.EnableBatchedOperations,
