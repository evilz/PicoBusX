@using PicoBusX.Web.Models
@inherits MessagePanelBase

<div class="peek-panel">
    <FluentCard Style="margin-bottom: 1rem;">
        <FluentStack Orientation="Orientation.Horizontal" Style="align-items: flex-end; gap: 1rem; flex-wrap: wrap;">
            <FluentNumberField Label="Max Messages"
                               @bind-Value="_maxCount"
                               Min="1"
                               Max="500"
                               Style="width: 120px;" />
            <FluentTextField Label="Filter"
                             @bind-Value="_filterText"
                             Placeholder="MessageId, Subject, Body…"
                             Style="flex: 1; min-width: 160px;"
                             Disabled="@IsBusy" />
            <FluentButton Appearance="Appearance.Accent"
                          IconStart="@(new Icons.Regular.Size16.Eye())"
                          OnClick="DoPeek"
                          Disabled="@IsBusy">
                @if (IsBusy) { <span>Loading…</span> } else { <span>Peek</span> }
            </FluentButton>
            <FluentButton Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size16.ArrowDownload())"
                          OnClick="DoReceive"
                          Disabled="@IsBusy">
                @if (IsBusy) { <span>Loading…</span> } else { <span>Receive</span> }
            </FluentButton>
            @if (HasMore && Messages.Any() && !IsBusy)
            {
                <FluentButton Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.ArrowDown())"
                              OnClick="DoLoadMore"
                              Disabled="@IsBusy">
                    Load More
                </FluentButton>
            }
        </FluentStack>
    </FluentCard>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <FluentMessageBar Intent="MessageIntent.Error" Style="margin-bottom: 1rem;">@ErrorMessage</FluentMessageBar>
    }

    <MessageList FilteredMessages="@FilterMessages(Messages)"
                 TotalCount="@Messages.Count"
                 HasMore="@HasMore"
                 IsBusy="@IsBusy"
                 ErrorMessage="@ErrorMessage"
                 CountLabel="message(s)"
                 EditorIdPrefix="peek-body"
                 Expanded="@_expanded"
                 OnToggle="ToggleMessage"
                 OnLoadMore="DoLoadMore">
        <BadgeContent Context="msg">
            @if (!string.IsNullOrEmpty(msg.Subject))
            {
                <FluentBadge Appearance="Appearance.Neutral" Style="font-size: 0.75rem;">@msg.Subject</FluentBadge>
            }
            <FluentBadge Appearance="Appearance.Neutral" Style="background: #f59e0b; color: white; font-size: 0.75rem;">DC:@msg.DeliveryCount</FluentBadge>
        </BadgeContent>
        <MetadataContent Context="msg">
            <FluentStack Orientation="Orientation.Horizontal" Style="flex-wrap: wrap; gap: 0.75rem; font-size: 0.8rem; margin-bottom: 0.75rem; background: var(--neutral-fill-rest); padding: 0.5rem; border-radius: 4px;">
                @if (!string.IsNullOrEmpty(msg.SessionId)) { <span><strong>SessionId:</strong> @msg.SessionId</span> }
                @if (!string.IsNullOrEmpty(msg.CorrelationId)) { <span><strong>CorrelationId:</strong> @msg.CorrelationId</span> }
                @if (!string.IsNullOrEmpty(msg.ContentType)) { <span><strong>ContentType:</strong> @msg.ContentType</span> }
                <span><strong>Enqueued:</strong> @msg.EnqueuedTime.ToString("yyyy-MM-dd HH:mm:ss zzz")</span>
            </FluentStack>
        </MetadataContent>
        <EmptyContent>
            <FluentCard Style="text-align: center; padding: 2rem; color: var(--neutral-foreground-hint);">
                Use Peek to preview messages (non-destructive) or Receive to consume them.
            </FluentCard>
        </EmptyContent>
    </MessageList>
</div>

@code {
    [Parameter] public EventCallback<(string, int)> OnReceive { get; set; }

    private async Task DoReceive() => await OnReceive.InvokeAsync((EntityPath, _maxCount));
}
