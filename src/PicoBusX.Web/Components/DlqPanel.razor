@using PicoBusX.Web.Models
@inherits MessagePanelBase

<div class="peek-panel">
    <FluentCard Style="margin-bottom: 1rem;">
        <FluentStack Orientation="Orientation.Horizontal" Style="align-items: flex-end; gap: 1rem; flex-wrap: wrap;">
            <FluentNumberField Label="Max Messages"
                               @bind-Value="_maxCount"
                               Min="1"
                               Max="500"
                               Style="width: 120px;" />
            <FluentTextField Label="Filter"
                             @bind-Value="_filterText"
                             Placeholder="MessageId, Subject, Body…"
                             Style="flex: 1; min-width: 160px;"
                             Disabled="@IsBusy" />
            <FluentButton Appearance="Appearance.Accent"
                          IconStart="@(new Icons.Regular.Size16.Eye())"
                          OnClick="DoPeek"
                          Disabled="@IsBusy">
                @if (IsBusy) { <span>Loading…</span> } else { <span>Peek DLQ</span> }
            </FluentButton>
            @if (HasMore && Messages.Any() && !IsBusy)
            {
                <FluentButton Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.ArrowDown())"
                              OnClick="DoLoadMore"
                              Disabled="@IsBusy">
                    Load More
                </FluentButton>
            }
        </FluentStack>
    </FluentCard>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <FluentMessageBar Intent="MessageIntent.Error" Style="margin-bottom: 1rem;">@ErrorMessage</FluentMessageBar>
    }

    @if (Messages.Any())
    {
        var filtered = FilterMessages(Messages);
        <div style="font-size: 0.8rem; color: var(--neutral-foreground-hint); margin-bottom: 0.5rem;">
            @if (filtered.Count < Messages.Count)
            {
                <span>Showing @filtered.Count of @Messages.Count dead-letter message(s)</span>
            }
            else
            {
                <span>Showing @Messages.Count dead-letter message(s)@(HasMore ? " — more available" : "")</span>
            }
        </div>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
            @foreach (var (msg, idx) in filtered.Select((m, i) => (m, i)))
            {
                var isExpanded = _expanded.Contains(msg.SequenceNumber);
                var isResubmitting = _resubmitting.Contains(msg.SequenceNumber);
                <FluentCard @key="msg.SequenceNumber" Style="padding: 0; overflow: hidden; border-left: 3px solid #f59e0b;">
                    <div class="message-header" @onclick="() => ToggleMessage(msg.SequenceNumber)" style="cursor: pointer; padding: 0.6rem 1rem; display: flex; align-items: center; gap: 0.75rem; user-select: none;">
                        <span style="color: var(--neutral-foreground-hint); font-size: 0.75rem; min-width: 24px;">#@(idx + 1)</span>
                        <span style="font-family: monospace; font-size: 0.8rem; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@(msg.MessageId ?? "—")</span>
                        <span style="color: var(--neutral-foreground-hint); font-size: 0.78rem;">@msg.EnqueuedTime.ToString("HH:mm:ss")</span>
                        @if (!string.IsNullOrEmpty(msg.DeadLetterReason))
                        {
                            <FluentBadge Appearance="Appearance.Neutral" Style="background: #dc2626; color: white; font-size: 0.75rem;">@msg.DeadLetterReason</FluentBadge>
                        }
                        <FluentIcon Value="@(isExpanded ? (Icon)new Icons.Regular.Size16.ChevronUp() : new Icons.Regular.Size16.ChevronDown())" Style="color: var(--neutral-foreground-hint);" />
                    </div>
                    @if (isExpanded)
                    {
                        <FluentDivider />
                        <div style="padding: 1rem;">
                            <FluentStack Orientation="Orientation.Horizontal" Style="flex-wrap: wrap; gap: 0.75rem; font-size: 0.8rem; margin-bottom: 0.75rem; background: var(--neutral-fill-rest); padding: 0.5rem; border-radius: 4px;">
                                <span><strong>Seq#:</strong> @msg.SequenceNumber</span>
                                @if (!string.IsNullOrEmpty(msg.DeadLetterReason)) { <span><strong>DL Reason:</strong> @msg.DeadLetterReason</span> }
                                @if (!string.IsNullOrEmpty(msg.DeadLetterErrorDescription)) { <span><strong>DL Error:</strong> @msg.DeadLetterErrorDescription</span> }
                                @if (!string.IsNullOrEmpty(msg.SessionId)) { <span><strong>SessionId:</strong> @msg.SessionId</span> }
                                @if (!string.IsNullOrEmpty(msg.CorrelationId)) { <span><strong>CorrelationId:</strong> @msg.CorrelationId</span> }
                                <span><strong>Enqueued:</strong> @msg.EnqueuedTime.ToString("yyyy-MM-dd HH:mm:ss zzz")</span>
                            </FluentStack>

                            <MessageApplicationProperties Properties="@msg.ApplicationProperties" />

                            <div style="margin-bottom: 0.75rem;">
                                <FluentLabel Weight="FontWeight.Bold" Style="display: block; margin-bottom: 0.35rem;">Body</FluentLabel>
                                <div style="border: 1px solid var(--neutral-stroke-rest); border-radius: 4px; overflow: hidden;">
                                    <StandaloneCodeEditor Id="@($"dlq-body-{msg.SequenceNumber}")"
                                                          ConstructionOptions="@(e => MonacoEditorOptions.ReadOnly(e, PrettyPrint(msg.Body)))"
                                                          CssClass="monaco-editor-host monaco-editor-readonly" />
                                </div>
                            </div>

                            <FluentButton Appearance="Appearance.Accent"
                                          IconStart="@(new Icons.Regular.Size16.ArrowCircleUp())"
                                          OnClick="() => DoResubmit(msg.SequenceNumber)"
                                          Disabled="@isResubmitting"
                                          Style="background: #f59e0b;">
                                @if (isResubmitting) { <span>Resubmitting…</span> } else { <span>Resubmit</span> }
                            </FluentButton>
                        </div>
                    }
                </FluentCard>
            }
        </FluentStack>
        @if (HasMore && !IsBusy)
        {
            <div style="text-align: center; margin-top: 1rem;">
                <FluentButton Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.ArrowDown())"
                              OnClick="DoLoadMore">
                    Load More
                </FluentButton>
            </div>
        }
    }
    else if (!IsBusy && string.IsNullOrEmpty(ErrorMessage))
    {
        <FluentCard Style="text-align: center; padding: 2rem; color: var(--neutral-foreground-hint);">
            <div aria-hidden="true">☠️</div>
            <div>No dead-letter messages. Use Peek DLQ to check.</div>
        </FluentCard>
    }
</div>

@code {
    [Parameter] public EventCallback<long> OnResubmit { get; set; }

    private HashSet<long> _resubmitting = new();

    private async Task DoResubmit(long sequenceNumber)
    {
        _resubmitting.Add(sequenceNumber);
        StateHasChanged();
        try
        {
            await OnResubmit.InvokeAsync(sequenceNumber);
        }
        finally
        {
            _resubmitting.Remove(sequenceNumber);
        }
    }
}
