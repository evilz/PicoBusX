@inherits LayoutComponentBase

<FluentDesignTheme StorageName="theme" />

<FluentLayout>
    <FluentHeader>
        <div class="header-brand">
            <span class="header-icon">🚌</span>
            <span class="header-title">PicoBusX</span>
            <span class="header-subtitle">Azure Service Bus Explorer</span>
        </div>
    </FluentHeader>
    <FluentStack Orientation="Orientation.Horizontal" Style="height: calc(100vh - 50px); overflow: hidden;">
        <div class="sidebar-container">
            @Body
        </div>
    </FluentStack>
</FluentLayout>

<FluentToastProvider />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
