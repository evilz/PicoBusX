@inherits LayoutComponentBase

<FluentDesignTheme StorageName="theme" />

<FluentLayout Class="aspire-shell">
    <FluentHeader Class="aspire-header">
        <FluentStack Orientation="Orientation.Horizontal"
                     HorizontalGap="8"
                     VerticalAlignment="VerticalAlignment.Center"
                     aria-label="PicoBusX application branding">
            <span class="aspire-logo" aria-hidden="true">🚌</span>
            <FluentAnchor Appearance="Appearance.Stealth" Href="/" Class="aspire-title">PicoBusX</FluentAnchor>
            <span class="aspire-subtitle">Azure Service Bus Explorer</span>
        </FluentStack>

        <FluentSpacer />

        <FluentAnchor Appearance="Appearance.Stealth"
                      Href="https://github.com/dotnet/aspire/tree/main/src/Aspire.Dashboard"
                      Target="_blank"
                      Rel="noreferrer noopener"
                      Class="header-button"
                      Title="Aspire Dashboard reference"
                      aria-label="Aspire Dashboard reference">
            <FluentIcon Value="@(new Icons.Regular.Size20.QuestionCircle())" />
        </FluentAnchor>
        <FluentAnchor Appearance="Appearance.Stealth"
                      Href="https://github.com/evilz/PicoBusX"
                      Target="_blank"
                      Rel="noreferrer noopener"
                      Class="header-button"
                      Title="PicoBusX repository"
                      aria-label="PicoBusX repository">
            <FluentIcon Value="@(new Icons.Regular.Size20.Code())" />
        </FluentAnchor>
    </FluentHeader>

    <FluentBodyContent Class="aspire-body">
        @Body
    </FluentBodyContent>
</FluentLayout>

<FluentToastProvider MaxToastCount="3" Timeout="5000" />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMenuProvider />
