@using PicoBusX.Web.Models

<div class="tree-panel">
    <div class="tree-search">
        <FluentSearch Placeholder="Filter..."
                      @bind-Value="_filter"
                      Style="width: 100%;" />
    </div>

    @if (IsLoading)
    {
        <div class="tree-loading">
            <FluentProgressRing Style="width: 24px; height: 24px;" />
            <span>Loading…</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <FluentMessageBar Intent="MessageIntent.Error" Style="margin: 0.5rem;">
            @ErrorMessage
        </FluentMessageBar>
    }
    else
    {
        <FluentTreeView>
            <FluentTreeItem Expanded="@_queuesExpanded"
                            OnExpandCollapse="e => _queuesExpanded = e.Expanded">
                <ChildContent>
                    <span class="tree-group-label">Queues (@FilteredQueues.Count)</span>
                    @foreach (var queue in FilteredQueues)
                    {
                        var queueCopy = queue;
                        <FluentTreeItem Selected="@IsSelected(queue)" OnClick="() => SelectQueue(queueCopy)">
                            <ChildContent>
                                <span class="tree-item-label">@queue.Name</span>
                                @if (queue.ActiveMessageCount > 0)
                                {
                                    <FluentBadge Appearance="Appearance.Accent" Style="margin-left: 0.35rem; font-size: 0.7rem;">@queue.ActiveMessageCount</FluentBadge>
                                }
                                @if (queue.DeadLetterMessageCount > 0)
                                {
                                    <FluentBadge Appearance="Appearance.Neutral" Style="margin-left: 0.25rem; font-size: 0.7rem; background: #f08030; color: white;">DL:@queue.DeadLetterMessageCount</FluentBadge>
                                }
                            </ChildContent>
                        </FluentTreeItem>
                    }
                    @if (!FilteredQueues.Any())
                    {
                        <FluentTreeItem Text="No queues match the filter" Disabled="true" />
                    }
                </ChildContent>
            </FluentTreeItem>

            <FluentTreeItem Expanded="@_topicsExpanded"
                            OnExpandCollapse="e => _topicsExpanded = e.Expanded">
                <ChildContent>
                    <span class="tree-group-label">Topics (@FilteredTopics.Count)</span>
                    @foreach (var topic in FilteredTopics)
                    {
                        var topicCopy = topic;
                        var topicExpanded = _expandedTopics.Contains(topic.Name);
                        <FluentTreeItem Selected="@IsTopicSelected(topic)"
                                        Expanded="@topicExpanded"
                                        OnExpandCollapse="e => OnTopicExpandCollapse(topicCopy.Name, e.Expanded)"
                                        OnClick="() => SelectTopic(topicCopy)">
                            <ChildContent>
                                <span class="tree-item-label">@topic.Name</span>
                                <span style="font-size: 0.72rem; opacity: 0.6; margin-left: 0.4rem;">@topic.Subscriptions.Count subs</span>
                                @foreach (var sub in topic.Subscriptions.Where(s => string.IsNullOrEmpty(_filter) || s.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase)))
                                {
                                    var subCopy = sub;
                                    <FluentTreeItem Selected="@IsSubSelected(sub)" OnClick="() => SelectSub(subCopy)">
                                        <ChildContent>
                                            <span class="tree-item-label">@sub.Name</span>
                                            @if (sub.ActiveMessageCount > 0)
                                            {
                                                <FluentBadge Appearance="Appearance.Accent" Style="margin-left: 0.35rem; font-size: 0.7rem;">@sub.ActiveMessageCount</FluentBadge>
                                            }
                                            @if (sub.DeadLetterMessageCount > 0)
                                            {
                                                <FluentBadge Appearance="Appearance.Neutral" Style="margin-left: 0.25rem; font-size: 0.7rem; background: #f08030; color: white;">DL:@sub.DeadLetterMessageCount</FluentBadge>
                                            }
                                        </ChildContent>
                                    </FluentTreeItem>
                                }
                            </ChildContent>
                        </FluentTreeItem>
                    }
                    @if (!FilteredTopics.Any())
                    {
                        <FluentTreeItem Text="No topics match the filter" Disabled="true" />
                    }
                </ChildContent>
            </FluentTreeItem>
        </FluentTreeView>
    }
</div>

@code {
    [Parameter] public List<QueueInfo> Queues { get; set; } = new();
    [Parameter] public List<TopicInfo> Topics { get; set; } = new();
    [Parameter] public EventCallback<BusEntity> OnEntitySelected { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }

    private string _filter = string.Empty;
    private bool _queuesExpanded = true;
    private bool _topicsExpanded = true;
    private HashSet<string> _expandedTopics = new();
    private BusEntity? _selected;

    private List<QueueInfo> FilteredQueues => string.IsNullOrEmpty(_filter)
        ? Queues
        : Queues.Where(q => q.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase)).ToList();

    private List<TopicInfo> FilteredTopics => string.IsNullOrEmpty(_filter)
        ? Topics
        : Topics.Where(t => t.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase)
            || t.Subscriptions.Any(s => s.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase))).ToList();

    private bool IsSelected(QueueInfo q) => _selected?.Type == BusEntityType.Queue && _selected.Name == q.Name;
    private bool IsTopicSelected(TopicInfo t) => _selected?.Type == BusEntityType.Topic && _selected.Name == t.Name;
    private bool IsSubSelected(SubscriptionInfo s) => _selected?.Type == BusEntityType.Subscription && _selected.Name == s.Name && _selected.TopicName == s.TopicName;

    private void OnTopicExpandCollapse(string topicName, bool expanded)
    {
        if (expanded) _expandedTopics.Add(topicName);
        else _expandedTopics.Remove(topicName);
    }

    private async Task SelectQueue(QueueInfo queue)
    {
        _selected = new BusEntity { Type = BusEntityType.Queue, Name = queue.Name };
        await OnEntitySelected.InvokeAsync(_selected);
    }

    private async Task SelectTopic(TopicInfo topic)
    {
        _selected = new BusEntity { Type = BusEntityType.Topic, Name = topic.Name };
        _expandedTopics.Add(topic.Name);
        await OnEntitySelected.InvokeAsync(_selected);
    }

    private async Task SelectSub(SubscriptionInfo sub)
    {
        _selected = new BusEntity { Type = BusEntityType.Subscription, Name = sub.Name, TopicName = sub.TopicName };
        await OnEntitySelected.InvokeAsync(_selected);
    }
}
