@using PicoBusX.Web.Formatting
@using PicoBusX.Web.Models

@if (Entity is not null)
{
    <div class="details-panel">
        @if (Entity.Type == BusEntityType.Queue)
        {
            var queue = Queues.FirstOrDefault(x => x.Name == Entity.Name);
            @if (queue is not null)
            {
                <FluentCard Style="padding: 0; overflow: hidden;">
                    <table class="details-table">
                        <tbody>
                            @foreach (var row in BuildQueueRows(queue))
                            {
                                <tr>
                                    <th>@row.Label</th>
                                    <td>@row.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </FluentCard>
            }
            else
            {
                <FluentMessageBar Intent="MessageIntent.Warning">Queue details not available.</FluentMessageBar>
            }
        }
        else if (Entity.Type == BusEntityType.Topic)
        {
            var topic = Topics.FirstOrDefault(x => x.Name == Entity.Name);
            @if (topic is not null)
            {
                <FluentCard Style="padding: 0; overflow: hidden; margin-bottom: 1rem;">
                    <table class="details-table">
                        <tbody>
                            @foreach (var row in BuildTopicRows(topic))
                            {
                                <tr>
                                    <th>@row.Label</th>
                                    <td>@row.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </FluentCard>

                <FluentLabel Weight="FontWeight.Bold" Style="display: block; margin-bottom: 0.5rem;">Subscriptions summary</FluentLabel>
                <FluentCard Style="padding: 0; overflow: hidden;">
                    <table class="details-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Active</th>
                                <th>DLQ</th>
                                <th>Transfer</th>
                                <th>Transfer DLQ</th>
                                <th>Sessions</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (topic.Subscriptions.Count == 0)
                            {
                                <tr>
                                    <td colspan="7">—</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var subscription in topic.Subscriptions)
                                {
                                    <tr>
                                        <td>@subscription.Name</td>
                                        <td>@subscription.ActiveMessageCount</td>
                                        <td>@subscription.DeadLetterMessageCount</td>
                                        <td>@subscription.TransferMessageCount</td>
                                        <td>@subscription.TransferDeadLetterMessageCount</td>
                                        <td>@EntityDisplayFormatter.FormatBoolean(subscription.RequiresSession)</td>
                                        <td>@EntityDisplayFormatter.FormatText(subscription.Status)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </FluentCard>
            }
            else
            {
                <FluentMessageBar Intent="MessageIntent.Warning">Topic details not available.</FluentMessageBar>
            }
        }
        else if (Entity.Type == BusEntityType.Subscription)
        {
            var topic = Topics.FirstOrDefault(x => x.Name == Entity.TopicName);
            var subscription = topic?.Subscriptions.FirstOrDefault(x => x.Name == Entity.Name);
            @if (subscription is not null)
            {
                <FluentCard Style="padding: 0; overflow: hidden;">
                    <table class="details-table">
                        <tbody>
                            @foreach (var row in BuildSubscriptionRows(subscription))
                            {
                                <tr>
                                    <th>@row.Label</th>
                                    <td>@row.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </FluentCard>
            }
            else
            {
                <FluentMessageBar Intent="MessageIntent.Warning">Subscription details not available.</FluentMessageBar>
            }
        }
    </div>
}

@code {
    [Parameter] public BusEntity? Entity { get; set; }
    [Parameter] public List<QueueInfo> Queues { get; set; } = new();
    [Parameter] public List<TopicInfo> Topics { get; set; } = new();

    private sealed record DetailRow(string Label, string Value);

    private static IReadOnlyList<DetailRow> BuildQueueRows(QueueInfo queue)
    {
        return
        [
            new("Name", queue.Name),
            new("Active Messages", queue.ActiveMessageCount.ToString()),
            new("Dead-Letter Messages", queue.DeadLetterMessageCount.ToString()),
            new("Transfer Dead-Letter Messages", queue.TransferDeadLetterMessageCount.ToString()),
            new("Scheduled Messages", queue.ScheduledMessageCount.ToString()),
            new("Transfer Messages", queue.TransferMessageCount.ToString()),
            new("Size", EntityDisplayFormatter.FormatSize(queue.SizeInBytes)),
            new("Max Size", EntityDisplayFormatter.FormatMegabytes(queue.MaxSizeInMegabytes)),
            new("Enable Partitioning", EntityDisplayFormatter.FormatBoolean(queue.EnablePartitioning)),
            ..BuildCommonQueueLikeRows(queue)
        ];
    }

    private static IReadOnlyList<DetailRow> BuildTopicRows(TopicInfo topic)
    {
        return
        [
            new("Name", topic.Name),
            new("Size", EntityDisplayFormatter.FormatSize(topic.SizeInBytes)),
            new("Scheduled Messages", topic.ScheduledMessageCount.ToString()),
            new("Created At", EntityDisplayFormatter.FormatDate(topic.CreatedAt)),
            new("Updated At", EntityDisplayFormatter.FormatDate(topic.UpdatedAt)),
            new("Accessed At", EntityDisplayFormatter.FormatDate(topic.AccessedAt)),
            new("Max Size", EntityDisplayFormatter.FormatMegabytes(topic.MaxSizeInMegabytes)),
            new("Default Message TTL", EntityDisplayFormatter.FormatTimeSpan(topic.DefaultMessageTimeToLive)),
            new("Auto Delete On Idle", EntityDisplayFormatter.FormatTimeSpan(topic.AutoDeleteOnIdle)),
            new("Enable Partitioning", EntityDisplayFormatter.FormatBoolean(topic.EnablePartitioning)),
            new("Enable Batched Operations", EntityDisplayFormatter.FormatBoolean(topic.EnableBatchedOperations)),
            new("Support Ordering", EntityDisplayFormatter.FormatBoolean(topic.SupportOrdering)),
            new("Duplicate Detection History Window", EntityDisplayFormatter.FormatTimeSpan(topic.DuplicateDetectionHistoryTimeWindow)),
            new("Requires Duplicate Detection", EntityDisplayFormatter.FormatBoolean(topic.RequiresDuplicateDetection)),
            new("Status", EntityDisplayFormatter.FormatText(topic.Status)),
            new("Subscriptions", topic.Subscriptions.Count.ToString())
        ];
    }

    private static IReadOnlyList<DetailRow> BuildSubscriptionRows(SubscriptionInfo subscription)
    {
        return
        [
            new("Topic", subscription.TopicName),
            new("Name", subscription.Name),
            new("Active Messages", subscription.ActiveMessageCount.ToString()),
            new("Dead-Letter Messages", subscription.DeadLetterMessageCount.ToString()),
            new("Transfer Messages", subscription.TransferMessageCount.ToString()),
            new("Transfer Dead-Letter Messages", subscription.TransferDeadLetterMessageCount.ToString()),
            new("Dead-Letter On Filter Evaluation Exceptions", EntityDisplayFormatter.FormatBoolean(subscription.DeadLetteringOnFilterEvaluationExceptions)),
            ..BuildCommonQueueLikeRows(subscription)
        ];
    }

    private static IReadOnlyList<DetailRow> BuildCommonQueueLikeRows(IQueueLikeEntity entity)
    {
        return
        [
            new("Created At", EntityDisplayFormatter.FormatDate(entity.CreatedAt)),
            new("Updated At", EntityDisplayFormatter.FormatDate(entity.UpdatedAt)),
            new("Accessed At", EntityDisplayFormatter.FormatDate(entity.AccessedAt)),
            new("Lock Duration", EntityDisplayFormatter.FormatTimeSpan(entity.LockDuration)),
            new("Max Delivery Count", entity.MaxDeliveryCount.ToString()),
            new("Requires Session", EntityDisplayFormatter.FormatBoolean(entity.RequiresSession)),
            new("Default Message TTL", EntityDisplayFormatter.FormatTimeSpan(entity.DefaultMessageTimeToLive)),
            new("Auto Delete On Idle", EntityDisplayFormatter.FormatTimeSpan(entity.AutoDeleteOnIdle)),
            new("Enable Batched Operations", EntityDisplayFormatter.FormatBoolean(entity.EnableBatchedOperations)),
            new("Forward To", EntityDisplayFormatter.FormatText(entity.ForwardTo)),
            new("Forward Dead-Lettered Messages To", EntityDisplayFormatter.FormatText(entity.ForwardDeadLetteredMessagesTo)),
            new("Dead-Letter On Message Expiration", EntityDisplayFormatter.FormatBoolean(entity.DeadLetteringOnMessageExpiration)),
            new("Status", EntityDisplayFormatter.FormatText(entity.Status))
        ];
    }
}
