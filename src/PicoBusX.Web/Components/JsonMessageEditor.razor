@using PicoBusX.Web.Models

<div class="send-panel">
    <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">

        <FluentTextField Label="Destination"
                         @bind-Value="_destination"
                         Placeholder="queue-name or topic-name"
                         Style="width: 100%;" />

        <div>
            <FluentLabel Weight="FontWeight.Bold" Style="display: block; margin-bottom: 0.35rem;">JSON Payload</FluentLabel>
            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; margin-bottom: 0.5rem;">
                <FluentButton Appearance="Appearance.Outline" OnClick="FormatJson" Title="Format JSON">
                    Format
                </FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="MinifyJson" Title="Minify JSON">
                    Minify
                </FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="ValidateJson" Title="Validate JSON">
                    Validate
                </FluentButton>
            </FluentStack>
            <textarea @bind="_jsonPayload"
                      rows="10"
                      class="json-editor @(_jsonError != null ? "editor-error" : "")"
                      placeholder="{}"
                      spellcheck="false"
                      style="width: 100%; box-sizing: border-box;"></textarea>
            @if (_jsonError is not null)
            {
                <FluentMessageBar Intent="MessageIntent.Error" Style="margin-top: 0.25rem;">@_jsonError</FluentMessageBar>
            }
            @if (_jsonValid && _jsonError is null)
            {
                <FluentMessageBar Intent="MessageIntent.Success" Style="margin-top: 0.25rem;">Valid JSON</FluentMessageBar>
            }
        </div>

        <FluentAccordion>
            <FluentAccordionItem Heading="Optional Headers">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem; padding: 0.5rem 0;">
                    <FluentGrid Spacing="2">
                        <FluentGridItem xs="12" sm="6">
                            <FluentTextField Label="Subject" @bind-Value="_subject" Style="width: 100%;" />
                        </FluentGridItem>
                        <FluentGridItem xs="12" sm="6">
                            <FluentTextField Label="MessageId" @bind-Value="_messageId" Placeholder="(auto-generated)" Style="width: 100%;" />
                        </FluentGridItem>
                        <FluentGridItem xs="12" sm="6">
                            <FluentTextField Label="CorrelationId" @bind-Value="_correlationId" Style="width: 100%;" />
                        </FluentGridItem>
                        <FluentGridItem xs="12" sm="6">
                            <FluentTextField Label="SessionId" @bind-Value="_sessionId" Style="width: 100%;" />
                        </FluentGridItem>
                        <FluentGridItem xs="12" sm="6">
                            <FluentTextField Label="Scheduled Enqueue Time (UTC, optional)"
                                             @bind-Value="_scheduledTime"
                                             Placeholder="e.g. 2025-12-31T09:00 or 2025-12-31 09:00:00"
                                             Style="width: 100%;" />
                        </FluentGridItem>
                    </FluentGrid>

                    <div>
                        <FluentLabel Weight="FontWeight.Bold" Style="display: block; margin-bottom: 0.5rem;">Application Properties</FluentLabel>
                        @foreach (var (key, idx) in _appProps.Select((p, i) => (p, i)))
                        {
                            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; margin-bottom: 0.4rem; align-items: flex-end;">
                                <FluentTextField Placeholder="Key" @bind-Value="_appProps[idx].Key" Style="flex: 1;" />
                                <FluentTextField Placeholder="Value" @bind-Value="_appProps[idx].Value" Style="flex: 2;" />
                                <FluentButton Appearance="Appearance.Outline"
                                              IconStart="@(new Icons.Regular.Size16.Dismiss())"
                                              OnClick="() => _appProps.RemoveAt(idx)"
                                              Style="color: #dc2626;" />
                            </FluentStack>
                        }
                        <FluentButton Appearance="Appearance.Outline"
                                      IconStart="@(new Icons.Regular.Size16.Add())"
                                      OnClick="() => _appProps.Add(new AppProp())">
                            Add Property
                        </FluentButton>
                    </div>
                </FluentStack>
            </FluentAccordionItem>
        </FluentAccordion>

        @if (!string.IsNullOrEmpty(SendResult))
        {
            <FluentMessageBar Intent="MessageIntent.Success">@SendResult</FluentMessageBar>
        }
        @if (!string.IsNullOrEmpty(SendError))
        {
            <FluentMessageBar Intent="MessageIntent.Error">@SendError</FluentMessageBar>
        }

        <div>
            <FluentButton Appearance="Appearance.Accent"
                          IconStart="@(new Icons.Regular.Size16.Send())"
                          OnClick="HandleSend"
                          Disabled="@(IsSending || _jsonError != null)"
                          Style="min-width: 160px;">
                @if (IsSending) { <span>Sending…</span> } else { <span>Send Message</span> }
            </FluentButton>
        </div>

    </FluentStack>
</div>

@code {
    [Parameter] public string Destination { get; set; } = string.Empty;
    [Parameter] public EventCallback<SendMessageRequest> OnSend { get; set; }
    [Parameter] public bool IsSending { get; set; }
    [Parameter] public string? SendResult { get; set; }
    [Parameter] public string? SendError { get; set; }

    private string _destination = string.Empty;
    private string _jsonPayload = "{\n  \n}";
    private string? _subject;
    private string? _messageId;
    private string? _correlationId;
    private string? _sessionId;
    private string? _scheduledTime;
    private string? _jsonError;
    private bool _jsonValid;
    private List<AppProp> _appProps = new();

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Destination) && string.IsNullOrEmpty(_destination))
            _destination = Destination;
    }

    private void FormatJson()
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(_jsonPayload);
            _jsonPayload = System.Text.Json.JsonSerializer.Serialize(doc.RootElement, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            _jsonError = null;
            _jsonValid = true;
        }
        catch (System.Text.Json.JsonException ex)
        {
            _jsonError = ex.Message;
            _jsonValid = false;
        }
    }

    private void MinifyJson()
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(_jsonPayload);
            _jsonPayload = System.Text.Json.JsonSerializer.Serialize(doc.RootElement);
            _jsonError = null;
            _jsonValid = true;
        }
        catch (System.Text.Json.JsonException ex)
        {
            _jsonError = ex.Message;
            _jsonValid = false;
        }
    }

    private void ValidateJson()
    {
        try
        {
            System.Text.Json.JsonDocument.Parse(_jsonPayload);
            _jsonError = null;
            _jsonValid = true;
        }
        catch (System.Text.Json.JsonException ex)
        {
            _jsonError = ex.Message;
            _jsonValid = false;
        }
    }

    private async Task HandleSend()
    {
        ValidateJson();
        if (_jsonError is not null) return;

        var request = new SendMessageRequest
        {
            Destination = _destination,
            JsonPayload = _jsonPayload,
            Subject = string.IsNullOrWhiteSpace(_subject) ? null : _subject,
            MessageId = string.IsNullOrWhiteSpace(_messageId) ? null : _messageId,
            CorrelationId = string.IsNullOrWhiteSpace(_correlationId) ? null : _correlationId,
            SessionId = string.IsNullOrWhiteSpace(_sessionId) ? null : _sessionId,
            ScheduledEnqueueTime = ParseScheduledTime(_scheduledTime),
            ApplicationProperties = _appProps
                .Where(p => !string.IsNullOrEmpty(p.Key))
                .GroupBy(p => p.Key)
                .ToDictionary(g => g.Key, g => g.Last().Value)
        };

        await OnSend.InvokeAsync(request);
    }

    private class AppProp
    {
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private static DateTimeOffset? ParseScheduledTime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return null;
        if (DateTimeOffset.TryParse(value, null, System.Globalization.DateTimeStyles.AssumeUniversal, out var result))
            return result;
        if (DateTime.TryParse(value, null, System.Globalization.DateTimeStyles.AssumeUniversal, out var dt))
            return new DateTimeOffset(dt, TimeSpan.Zero);
        return null;
    }
}
